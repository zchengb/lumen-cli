# Local secrets and machine-specific values.
# Copy this file to .env.local and fill in values locally.
# .env.local must never be committed.

FEISHU_WEBHOOK_URL=""
CURSOR_API_KEY=""

# Optional: only needed when a non-interactive scheduled job cannot use an
# existing `gh auth login` session to create pull requests.
# GH_HOST=""
# GH_TOKEN=""

# Visual Delivery login credentials are saved in config/repos.json per repository:
#   lumen config set-visual-auth <repository> <credential> --project <slug>
# Optional legacy fallback when auth_login_path is not configured:
# LUMEN_VISUAL_STORAGE_STATE="/absolute/path/to/storage-state.json"
