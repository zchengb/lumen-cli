# Shared non-secret defaults for reusable Lumen deployments.
# Copy to .env.common if a team wants common local defaults.

AUTO_SCAN_CONFIG_DIR="config"
AUTO_SCAN_RESULTS_DIR="results"
AUTO_SCAN_REPORTS_DIR="reports"
AUTO_SCAN_LOGS_DIR="logs"
AUTO_SCAN_TMP_DIR="tmp"
AUTO_SCAN_DEFAULT_WINDOW_DAYS="7"
AUTO_SCAN_EXECUTION_MODE="lightweight_review_only"
AUTO_SCAN_RUN_PROJECT_COMMANDS="false"
