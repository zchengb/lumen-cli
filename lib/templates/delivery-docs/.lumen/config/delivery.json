{
  "schema_version": "1.0",
  "execution": {
    "model": "composer-2.5",
    "sandbox": "disabled"
  },
  "jira": {
    "enabled": true,
    "auto_enable_when_twg_ready": true,
    "site": "",
    "in_dev_status": "IN DEV",
    "dev_done_status": "DEV DONE"
  },
  "notifications": {
    "feishu": {
      "enabled": true
    }
  },
  "verification": {
    "auto_run_after_agent": true,
    "fail_on_error": true,
    "docker": {
      "mode": "host_testcontainers",
      "required_for": ["integration_test"],
      "check_before_run": true,
      "skip_if_unavailable": false
    },
    "java_gradle": {
      "strategy": "compile, PMD when configured, then full Gradle test suite"
    },
    "steps": {}
  }
}
