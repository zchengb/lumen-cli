{
  "schema_version": "1.0",
  "execution": {
    "model": "composer-2.5",
    "sandbox": "disabled",
    "approve_mcps": false
  },
  "jira": {
    "enabled": true,
    "auto_enable_when_twg_ready": true,
    "site": "",
    "in_dev_status": "IN DEV",
    "dev_done_status": "DEV DONE"
  },
  "notifications": {
    "feishu": {
      "enabled": true
    }
  },
  "observability": {
    "agent_trace": {
      "enabled": true,
      "capture_mode": "metadata",
      "retention_days": 14
    }
  },
  "automation": {
    "cleanup_worktrees_on_success": true,
    "scheduled_delivery": {
      "enabled": false,
      "required_jira_status": "Ready for Dev"
    }
  },
  "verification": {
    "auto_run_after_agent": true,
    "fail_on_error": true,
    "remediation": {
      "enabled": true,
      "max_attempts": 2
    },
    "docker": {
      "mode": "host_testcontainers",
      "required_for": ["integration_test"],
      "check_before_run": true,
      "skip_if_unavailable": false
    },
    "java_gradle": {
      "strategy": "compile, PMD when configured, then full Gradle test suite"
    },
    "steps": {}
  }
}
