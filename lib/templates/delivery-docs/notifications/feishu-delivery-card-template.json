{
  "schema_version": "1.0",
  "template_name": "lumen-delivery-progress",
  "description": "Feishu interactive card template for Lumen delivery progress notifications.",
  "events": [
    "delivery.started",
    "delivery.blocked",
    "delivery.failed",
    "delivery.pr.created",
    "delivery.dev_done",
    "delivery.change_recorded",
    "delivery.refactor_recorded"
  ],
  "variables": {
    "event_title": "{{event_title}}",
    "jira_key": "{{jira_key}}",
    "story_title": "{{story_title}}",
    "summary": "{{summary}}",
    "status": "{{status}}",
    "triggered_by": "{{triggered_by}}",
    "current_step": "{{current_step}}",
    "repos": "{{repos}}",
    "branch": "{{branch}}",
    "duration": "{{duration}}",
    "verification_summary": "{{verification_summary}}",
    "change_records": "{{change_records}}",
    "refactor_records": "{{refactor_records}}",
    "docs_url": "{{docs_url}}",
    "dashboard_url": "{{dashboard_url}}",
    "logs_url": "{{logs_url}}"
  },
  "card_preview": {
    "title": "{{event_title}}",
    "subtitle": "{{jira_key}} · {{story_title}}",
    "sections": [
      "Status: {{status}}",
      "Triggered By: {{triggered_by}}",
      "Current Step: {{current_step}}",
      "Repos: {{repos}}",
      "Branch: {{branch}}",
      "Duration: {{duration}}",
      "Verification: {{verification_summary}}",
      "CR: {{change_records}}",
      "RF: {{refactor_records}}"
    ],
    "card_link": "{{jira_url}}"
  }
}
