#!/usr/bin/env bash
set -euo pipefail

LUMEN_CLI_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
LUMEN_CLI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [[ -z "${LUMEN_HOME:-}" && -f "${LUMEN_CLI_ROOT}/lib/scripts/workspace_config.py" ]]; then
  LUMEN_HOME="${LUMEN_CLI_ROOT}"
else
  LUMEN_HOME="${LUMEN_HOME:-$HOME/.lumen}"
fi
if [[ -f "${LUMEN_HOME}/lib/scripts/ensure-path.sh" ]]; then
  # shellcheck source=/dev/null
  source "${LUMEN_HOME}/lib/scripts/ensure-path.sh"
  ensure_lumen_path "${LUMEN_CLI_BIN}"
fi

LUMEN_LIB_DIR="${LUMEN_HOME}/lib/scripts"
LUMEN_TEMPLATES_DIR="${LUMEN_HOME}/lib/templates"
LUMEN_VERSION_FILE="${LUMEN_HOME}/VERSION"
PROJECTS_REGISTRY_PY="${LUMEN_HOME}/lib/scripts/projects_registry.py"

RESOLVED_WORKSPACE=""
RESOLVED_PROJECT_SLUG=""
RESOLVED_REMAINING_ARGS=()

RED="$(printf '\033[31m')"
GREEN="$(printf '\033[32m')"
YELLOW="$(printf '\033[33m')"
BOLD="$(printf '\033[1m')"
RESET="$(printf '\033[0m')"

err() { printf '%sError:%s %s\n' "${RED}" "${RESET}" "$1" >&2; }
ok()  { printf '%s✓%s %s\n' "${GREEN}" "${RESET}" "$1"; }
warn() { printf '%s!%s %s\n' "${YELLOW}" "${RESET}" "$1"; }

require_python3() {
  if ! command -v python3 >/dev/null 2>&1; then
    err "Python 3 is required. Install it with: xcode-select --install  (or: brew install python3)"
    exit 1
  fi
}

json_get() {
  local json="$1"
  local key="$2"
  printf '%s' "${json}" | python3 -c "import json,sys; d=json.load(sys.stdin); v=d.get('${key}'); print('' if v is None else v, end='')"
}

json_array_length() {
  local json="$1"
  printf '%s' "${json}" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))"
}

json_array_items() {
  local json="$1"
  printf '%s' "${json}" | python3 -c "import json,sys; data=json.load(sys.stdin); [print(json.dumps(item)) for item in data]"
}

lumen_version() {
  if [[ -f "${LUMEN_VERSION_FILE}" ]]; then
    tr -d '[:space:]' < "${LUMEN_VERSION_FILE}"
  else
    echo "unknown"
  fi
}

LUMEN_DIR_NAME="lumen"
LEGACY_LUMEN_DIR_NAME=".lumen"

is_lumen_workspace() {
  [[ -f "$1/config/common.json" ]]
}

default_lumen_workspace_path() {
  local project_root="$1"
  printf '%s/%s' "$(cd "${project_root}" && pwd)" "${LUMEN_DIR_NAME}"
}

resolve_lumen_workspace_path() {
  local input="$1"
  input="$(cd "${input}" && pwd)"
  if is_lumen_workspace "${input}"; then
    printf '%s' "${input}"
    return 0
  fi
  if is_lumen_workspace "${input}/${LUMEN_DIR_NAME}"; then
    printf '%s' "$(cd "${input}/${LUMEN_DIR_NAME}" && pwd)"
    return 0
  fi
  if is_lumen_workspace "${input}/${LEGACY_LUMEN_DIR_NAME}"; then
    printf '%s' "$(cd "${input}/${LEGACY_LUMEN_DIR_NAME}" && pwd)"
    return 0
  fi
  return 1
}

migrate_workspace_dir() {
  local workspace="$1" root target
  [[ "$(basename "${workspace}")" == "${LEGACY_LUMEN_DIR_NAME}" ]] || { printf '%s' "${workspace}"; return 0; }
  root="$(dirname "${workspace}")"
  target="${root}/${LUMEN_DIR_NAME}"
  if [[ -e "${target}" ]]; then
    printf '%s' "${workspace}"
    return 0
  fi
  if find "${workspace}/worktrees" -mindepth 2 -maxdepth 2 -type f -name .git -print -quit 2>/dev/null | grep -q .; then
    warn "Workspace migration deferred: ${LEGACY_LUMEN_DIR_NAME}/ contains active Git worktrees. Use Git worktree move or clean them up before migrating to ${LUMEN_DIR_NAME}/." >&2
    printf '%s' "${workspace}"
    return 0
  fi
  mv "${workspace}" "${target}"
  ok "Migrated workspace directory: ${LEGACY_LUMEN_DIR_NAME}/ -> ${LUMEN_DIR_NAME}/" >&2
  printf '%s' "${target}"
}

resolve_workspace() {
  local workspace="."
  local args=("$@")
  local i=0
  for ((i = 0; i < ${#args[@]}; i++)); do
    if [[ "${args[$i]}" == "--workspace" && -n "${args[$((i + 1))]:-}" ]]; then
      workspace="${args[$((i + 1))]}"
    fi
  done
  cd "${workspace}" 2>/dev/null || { err "Workspace directory not found: ${workspace}"; exit 1; }
  pwd
}

require_registry_python() {
  require_python3
  if [[ ! -f "${PROJECTS_REGISTRY_PY}" ]]; then
    err "Project registry script not found. Re-run install.sh to repair your Lumen CLI installation."
    exit 1
  fi
}

registry_cmd() {
  require_registry_python
  python3 "${PROJECTS_REGISTRY_PY}" "$@"
}

register_project_workspace() {
  local workspace="$1"
  local name="${2:-}"
  require_workspace_initialized "${workspace}"
  if [[ -n "${name}" ]]; then
    registry_cmd add "${workspace}" --name "${name}"
  else
    registry_cmd add "${workspace}"
  fi
}

try_register_project() {
  local workspace="$1"
  local name="${2:-}"
  if ! command -v python3 >/dev/null 2>&1 || [[ ! -f "${PROJECTS_REGISTRY_PY}" ]]; then
    warn "Skipped project registry (Python 3 required). Run 'lumen register ${workspace}' later."
    return 0
  fi
  local project_json project_slug project_name
  project_json="$(register_project_workspace "${workspace}" "${name}")"
  project_slug="$(json_get "${project_json}" slug)"
  project_name="$(json_get "${project_json}" name)"
  ok "Registered project '${project_name}' (slug: ${project_slug})"
  printf 'Run: %slumen scan --project %s%s\n' "${BOLD}" "${project_slug}" "${RESET}"
}

workspace_display_name() {
  local workspace="$1"
  if command -v python3 >/dev/null 2>&1; then
    python3 -c "import json; c=json.load(open('${workspace}/config/common.json')); print((c.get('project') or {}).get('display_name') or '', end='')" 2>/dev/null || true
  fi
}

prompt_project_selection() {
  local lines=()
  local line
  while IFS= read -r line; do
    lines+=("${line}")
  done < <(registry_cmd list-lines)

  if [[ "${#lines[@]}" -eq 0 ]]; then
    err "No projects registered."
    printf 'Run %slumen init%s or %slumen register <workspace-dir>%s first.\n' "${BOLD}" "${RESET}" "${BOLD}" "${RESET}"
    exit 1
  fi

  printf '\n%sSelect your project:%s\n' "${BOLD}" "${RESET}"
  local entry num id slug name workspace
  for entry in "${lines[@]}"; do
    IFS=$'\t' read -r num id slug name workspace <<< "${entry}"
    printf '  [%s] %s — %s\n' "${num}" "${slug}" "${name}"
  done

  local choice=""
  read -r -p "Choose [1-${#lines[@]}]: " choice || true
  if [[ -z "${choice}" ]]; then
    choice=1
  fi
  if ! [[ "${choice}" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#lines[@]} )); then
    err "Invalid selection."
    exit 1
  fi

  IFS=$'\t' read -r num id slug name workspace <<< "${lines[$((choice - 1))]}"
  RESOLVED_WORKSPACE="${workspace}"
  RESOLVED_PROJECT_SLUG="${slug}"
  printf 'Using project: %s (lumen scan --project %s)\n' "${name}" "${slug}"
}

resolve_command_workspace() {
  local args=("$@")
  local project_slug="" workspace_arg="" explicit_workspace="0"
  local i=0

  RESOLVED_REMAINING_ARGS=()

  while (( i < ${#args[@]} )); do
    case "${args[$i]}" in
      --project|-p)
        project_slug="${args[$((i + 1))]:-}"
        i=$((i + 2))
        ;;
      --workspace)
        workspace_arg="${args[$((i + 1))]:-}"
        explicit_workspace="1"
        i=$((i + 2))
        ;;
      --open|--no-open)
        RESOLVED_REMAINING_ARGS+=("${args[$i]}")
        i=$((i + 1))
        ;;
      --*)
        err "Unknown option: ${args[$i]}"
        exit 1
        ;;
      *)
        err "Unexpected argument: ${args[$i]}. Use --project <slug> to select a project."
        exit 1
        ;;
    esac
  done

  if [[ -n "${project_slug}" ]]; then
    RESOLVED_WORKSPACE="$(registry_cmd resolve-slug "${project_slug}" --workspace-only)"
    require_workspace_initialized "${RESOLVED_WORKSPACE}"
    return 0
  fi

  if [[ -n "${LUMEN_PROJECT:-}" ]]; then
    RESOLVED_WORKSPACE="$(registry_cmd resolve-slug "${LUMEN_PROJECT}" --workspace-only)"
    require_workspace_initialized "${RESOLVED_WORKSPACE}"
    return 0
  fi

  if [[ "${explicit_workspace}" == "1" ]]; then
    RESOLVED_WORKSPACE="$(cd "${workspace_arg}" 2>/dev/null && pwd)" || {
      err "Workspace directory not found: ${workspace_arg}"
      exit 1
    }
    require_workspace_initialized "${RESOLVED_WORKSPACE}"
    return 0
  fi

  if [[ -f "./${LUMEN_DIR_NAME}/config/common.json" ]]; then
    RESOLVED_WORKSPACE="$(cd "./${LUMEN_DIR_NAME}" && pwd)"
    require_workspace_initialized "${RESOLVED_WORKSPACE}"
    return 0
  fi

  if [[ -f "./config/common.json" ]]; then
    RESOLVED_WORKSPACE="$(pwd)"
    require_workspace_initialized "${RESOLVED_WORKSPACE}"
    return 0
  fi

  require_registry_python
  local count
  count="$(registry_cmd count | tr -d '[:space:]')"

  if [[ "${count}" == "0" ]]; then
    err "No Lumen workspace in the current directory and no projects registered."
    printf 'Run %slumen init%s to create one, or %slumen register <workspace-dir>%s to add an existing workspace.\n' "${BOLD}" "${RESET}" "${BOLD}" "${RESET}"
    exit 1
  fi

  if registry_cmd get-default --workspace-only >/dev/null 2>&1; then
    RESOLVED_WORKSPACE="$(registry_cmd get-default --workspace-only)"
    local default_slug default_name
    default_slug="$(json_get "$(registry_cmd get-default)" slug)"
    default_name="$(json_get "$(registry_cmd get-default)" name)"
    printf 'Using default project: %s (lumen scan --project %s)\n' "${default_name}" "${default_slug}"
    require_workspace_initialized "${RESOLVED_WORKSPACE}"
    return 0
  fi

  if [[ "${count}" == "1" ]]; then
    local only_line
    only_line="$(registry_cmd list-lines)"
    IFS=$'\t' read -r num id slug name workspace <<< "${only_line}"
    RESOLVED_WORKSPACE="${workspace}"
    printf 'Using project: %s (lumen scan --project %s)\n' "${name}" "${slug}"
    require_workspace_initialized "${RESOLVED_WORKSPACE}"
    return 0
  fi

  if [[ -t 0 && -t 1 ]]; then
    prompt_project_selection
    require_workspace_initialized "${RESOLVED_WORKSPACE}"
    return 0
  fi

  err "Multiple projects registered. Pass --project <slug>, set a default with 'lumen use <slug>', or pass --workspace <dir>."
  registry_cmd list
  exit 1
}

require_workspace_initialized() {
  local workspace="$1"
  if ! is_lumen_workspace "${workspace}"; then
    err "No Lumen workspace found at: ${workspace}"
    printf 'Run: %slumen init%s in your project root to create %s/, or pass --workspace <dir>.\n' "${BOLD}" "${RESET}" "${LUMEN_DIR_NAME}"
    exit 1
  fi
}

cmd_help() {
  cat <<'EOF'
Lumen - illuminate code health across your repositories

Usage:
  lumen init [workspace-dir] [--yes] [--force]
                                 Create one integrated Lumen workspace: stories/, repos/, AGENTS.md, and lumen/.
                                 Pass --yes (or run non-interactively) to skip prompts and use templates.
                                 If a previous init was interrupted, init removes the incomplete
                                 lumen folder and starts again. Use --force to replace a fully
                                 configured workspace.
  lumen list                    List all registered scan projects (name and slug)
  lumen remove <slug> [--yes]   Remove a registered project and its scheduled scan
                                 Add --delete-workspace --yes to also delete its lumen workspace
  lumen rename <slug> --slug <new-slug>
                                 Change a project's unique registry slug
  lumen use [slug]              Set or show the default project slug
  lumen register [dir]          Register an existing workspace as a scan project
  lumen scan --project <slug> [--dry-run]
                                 Run a scan for a specific project
                                 Add --dry-run to mock the pipeline without the Cursor agent
  lumen schedule                List all scan and delivery schedules
  lumen schedule scan add [--project <slug>] [--cron "<cron-expr>"] [--dry-run]
                                 Schedule recurring code scans
  lumen schedule delivery add --project <slug> --every 5m
                                 Poll approved Stories and start JIRA Ready for Dev deliveries
                                 Aliases: lumen scan schedule ..., lumen delivery schedule ...
  lumen watch --project <slug>  Watch the latest scan log in real time
  lumen issue list [--project <slug>] [--status open|ignored|resolved|all] [--json]
                                 List tracked findings from the issue registry
  lumen issue ignore <issue-id> [--project <slug>]
                                 Mark a tracked finding as ignored in the issue registry
  lumen dashboard [stop] --project <slug> [--no-open] [--static]
                                 Open the local interactive dashboard for issues, schedules,
                                 prompts, and workspace configuration. Pass --static for the
                                 read-only generated HTML file.
  lumen delivery run [--story <slug>] [--dry-run] [workspace-dir]
                                 Implement an approved technical plan with the Lumen delivery agent
  lumen delivery status [workspace-dir|--workspace <root>]
                                 Show detailed delivery progress for the latest run
  lumen delivery dashboard [workspace-dir] [--no-open]
                                 Render the Delivery history dashboard for one workspace
  lumen delivery watch [workspace-dir|--workspace <root>]
                                 Watch the latest delivery log and progress in real time
  lumen doctor                  Check that required and optional tools are installed
  lumen config set-webhook <url> [--project <slug>]
                                 Save the Feishu webhook in this workspace's .env.local
  lumen config set-cursor-api-key <key> [--project <slug>]
                                 Save CURSOR_API_KEY in this workspace's .env.local (for scheduled scans)
  lumen config set-gh-token <token> [--host <github-host>] [--project <slug>]
                                 Save GH_TOKEN (and optional GH_HOST) for scheduled PR creation on GHE/GitHub
  lumen config set-scan-window <days> [--project <slug>]
                                 Set how many days of git history each scan inspects
  lumen config set-visual-auth <repository> <credential> [--project <slug>]
                                 Save a Visual Delivery login credential in config/repos.json
  lumen config set-jira [--enable|--disable] [--project-key <key>]
                                 [--board-id <id>] [--no-active-sprint] [--project <slug>]
                                 Enable or update Jira sync (TWG CLI) for this workspace
  lumen config show [--project <slug>]
                                 Show workspace settings (scan window, webhook, model)
  lumen config unset-webhook [--project <slug>]
                                 Remove the Feishu webhook from a workspace
  lumen config unset-cursor-api-key [--project <slug>]
                                 Remove CURSOR_API_KEY from a workspace
  lumen upgrade [--cli-only] [--project <slug>]
                                 Upgrade the installed Lumen CLI to the latest release and
                                 refresh this workspace's bundled templates (prompts/scan/,
                                 prompts/delivery/, runtime-profiles.json, feishu-card-template.json,
                                 dashboard.html).
                                 Add --cli-only to upgrade only the CLI without touching workspace
                                 templates. Use --project <slug> to target a specific workspace.
  lumen skills install --workspace <path> --platform claude|cursor|codex|all [--force]
                                 Install explicit Lumen workflow skills for a project.
  lumen version                 Print the installed Lumen CLI version
  lumen help                    Show this help message

Environment:
  LUMEN_HOME                    Lumen CLI installation directory (default: ~/.lumen)
  CURSOR_AGENT_MODEL            Overrides the Cursor model set in config/common.json (execution.model)
  FEISHU_WEBHOOK_URL            Optional shell override for a workspace Feishu webhook

Feishu webhook resolution order (highest priority first):
  1. FEISHU_WEBHOOK_URL in the current shell environment
  2. <workspace>/.env.local (per-project, set with 'lumen config set-webhook <url> --project <slug>')

Project registry:
  Registered projects are stored in ~/.lumen/projects.json
  Select a project by slug:
    lumen scan --project mbpass
    lumen use mbpass && lumen scan
    LUMEN_PROJECT=mbpass lumen scan
  Run 'lumen list' to see available slugs.

Docs:
  See README.md in a Lumen workspace after running 'lumen init'.
EOF
}

cmd_version() {
  printf 'lumen %s\n' "$(lumen_version)"
}

cmd_skills() {
  local sub="${1:-}"
  shift || true
  case "${sub}" in
    install)
      require_python3
      local installer="${LUMEN_LIB_DIR}/install_agent_skills.py"
      [[ -f "${installer}" ]] || { err "Skills installer not found. Re-run install.sh to repair Lumen."; exit 1; }
      python3 "${installer}" "$@"
      ;;
    *)
      err "Usage: lumen skills install --workspace <path> --platform claude|cursor|codex|all [--force]"
      exit 1
      ;;
  esac
}

sync_prompt_snippets() {
  local workspace="$1"
  local src_dir="${LUMEN_TEMPLATES_DIR}/prompts/scan"
  local dest_dir="${workspace}/prompts/scan"
  if [[ ! -d "${src_dir}" ]]; then
    return 0
  fi
  mkdir -p "${dest_dir}"
  local source relative destination
  while IFS= read -r source; do
    relative="${source#${src_dir}/}"
    destination="${dest_dir}/${relative}"
    if [[ ! -e "${destination}" ]]; then
      mkdir -p "$(dirname "${destination}")"
      cp "${source}" "${destination}"
    fi
  done < <(find "${src_dir}" -type f)
}

sync_delivery_prompt_snippets() {
  local workspace="$1"
  local src_dir="${LUMEN_TEMPLATES_DIR}/prompts/delivery"
  local dest_dir="${workspace}/prompts/delivery"
  [[ -d "${src_dir}" ]] || return 0
  mkdir -p "${dest_dir}"
  local source relative destination
  while IFS= read -r source; do
    relative="${source#${src_dir}/}"
    destination="${dest_dir}/${relative}"
    if [[ ! -e "${destination}" ]]; then
      mkdir -p "$(dirname "${destination}")"
      cp "${source}" "${destination}"
    fi
  done < <(find "${src_dir}" -type f)
  local guideline_source="${LUMEN_HOME}/lib/standards/coding-guideline.md"
  local guideline_destination="${dest_dir}/coding-guideline.md"
  if [[ -f "${guideline_source}" && ! -e "${guideline_destination}" ]]; then
    cp "${guideline_source}" "${guideline_destination}"
  fi
}

migrate_legacy_scan_prompts() {
  local workspace="$1" backup_dir="$2"
  local legacy_dir="${workspace}/config/prompts"
  local prompts_dir="${workspace}/prompts/scan"
  [[ -d "${legacy_dir}" ]] || return 0

  if [[ ! -d "${prompts_dir}" ]]; then
    mkdir -p "$(dirname "${prompts_dir}")"
    mv "${legacy_dir}" "${prompts_dir}"
    ok "Moved editable scan prompts to prompts/scan/."
    return 0
  fi

  local source relative destination
  while IFS= read -r source; do
    relative="${source#${legacy_dir}/}"
    destination="${prompts_dir}/${relative}"
    if [[ ! -e "${destination}" ]]; then
      mkdir -p "$(dirname "${destination}")"
      cp "${source}" "${destination}"
    fi
  done < <(find "${legacy_dir}" -type f)
  mv "${legacy_dir}" "${backup_dir}/legacy-scan-prompts"
  ok "Archived legacy config/prompts/ after preserving any missing snippets."
}

sync_workspace_templates() {
  local workspace="$1"
  local stamp
  stamp="$(date -u '+%Y%m%d-%H%M%S')"
  local backup_dir="${workspace}/config/.template-backups/${stamp}"
  mkdir -p "${backup_dir}"

  local file
  for file in runtime-profiles.json feishu-card-template.json; do
    if [[ -f "${workspace}/config/${file}" ]]; then
      cp "${workspace}/config/${file}" "${backup_dir}/${file}"
    fi
    if [[ -f "${LUMEN_TEMPLATES_DIR}/config/${file}" ]]; then
      cp "${LUMEN_TEMPLATES_DIR}/config/${file}" "${workspace}/config/${file}"
    fi
  done

  if [[ -d "${workspace}/prompts" ]]; then
    mkdir -p "${backup_dir}/prompts"
    cp -R "${workspace}/prompts/." "${backup_dir}/prompts/"
  elif [[ -d "${workspace}/config/prompts" ]]; then
    mkdir -p "${backup_dir}/prompts/scan"
    cp -R "${workspace}/config/prompts/." "${backup_dir}/prompts/scan/"
  fi
  migrate_legacy_scan_prompts "${workspace}" "${backup_dir}"
  sync_prompt_snippets "${workspace}"
  sync_delivery_prompt_snippets "${workspace}"

  if [[ -f "${workspace}/dashboard.html" ]]; then
    cp "${workspace}/dashboard.html" "${backup_dir}/dashboard.html"
  fi
  if [[ -f "${LUMEN_TEMPLATES_DIR}/dashboard.html" ]]; then
    cp "${LUMEN_TEMPLATES_DIR}/dashboard.html" "${workspace}/dashboard.html"
  fi
  if [[ -d "${LUMEN_TEMPLATES_DIR}/assets" ]]; then
    mkdir -p "${workspace}/assets"
    cp -R "${LUMEN_TEMPLATES_DIR}/assets/." "${workspace}/assets/"
  fi
  if [[ -d "${LUMEN_TEMPLATES_DIR}/dashboard-app" ]]; then
    rm -rf "${workspace}/dashboard-app"
    mkdir -p "${workspace}/dashboard-app"
    cp -R "${LUMEN_TEMPLATES_DIR}/dashboard-app/." "${workspace}/dashboard-app/"
  fi

  ok "Refreshed workspace templates. Existing prompt files were preserved; missing defaults were added."
  printf '  Workspace: %s\n' "${workspace}"
  printf '  Previous versions backed up to: %s\n' "${backup_dir}"
  printf '  config/common.json and config/repos.json were left untouched (they hold your project data).\n'
}

cmd_upgrade() {
  local sync_prompts="1"
  local cli_only="0"
  local passthrough_args=()
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --sync-prompts) sync_prompts="1" ;;
      --cli-only) cli_only="1"; sync_prompts="0" ;;
      *) passthrough_args+=("${arg}") ;;
    esac
  done

  local repo="${LUMEN_REPO:-zchengb/lumen-cli}"
  local before_version
  before_version="$(lumen_version)"

  printf '%sUpgrading Lumen CLI (current: %s, repo: %s)...%s\n' "${BOLD}" "${before_version}" "${repo}" "${RESET}"

  local installer_url="https://raw.githubusercontent.com/${repo}/main/get.sh"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${installer_url}" | LUMEN_REPO="${repo}" LUMEN_HOME="${LUMEN_HOME}" bash
  elif command -v wget >/dev/null 2>&1; then
    wget -qO- "${installer_url}" | LUMEN_REPO="${repo}" LUMEN_HOME="${LUMEN_HOME}" bash
  else
    err "Neither curl nor wget is available to fetch the Lumen CLI upgrade."
    exit 1
  fi

  local after_version
  after_version="$(lumen_version)"
  if [[ "${after_version}" == "${before_version}" ]]; then
    ok "Lumen CLI is already up to date (${after_version})."
  else
    ok "Lumen CLI upgraded: ${before_version} -> ${after_version}."
  fi

  if [[ "${sync_prompts}" == "1" ]]; then
    if resolve_command_workspace "${passthrough_args[@]+"${passthrough_args[@]}"}" 2>/dev/null; then
      RESOLVED_WORKSPACE="$(migrate_workspace_dir "${RESOLVED_WORKSPACE}")"
      sync_workspace_templates "${RESOLVED_WORKSPACE}"
    elif [[ -t 0 && -t 1 ]]; then
      printf '\n%sSelect a workspace to refresh bundled templates:%s\n' "${BOLD}" "${RESET}"
      prompt_project_selection
      sync_workspace_templates "${RESOLVED_WORKSPACE}"
    else
      warn "No workspace resolved. Run: lumen upgrade --project <slug> to refresh bundled templates."
    fi
  fi
}

load_env_file_if_present() {
  local file="$1"
  if [[ -f "${file}" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "${file}"
    set +a
  fi
}

cmd_doctor() {
  printf '%sLumen environment check%s\n\n' "${BOLD}" "${RESET}"

  if command -v agent >/dev/null 2>&1; then
    ok "Cursor CLI (agent) found: $(command -v agent)"
  else
    err "Cursor CLI (agent) not found. Install from https://cursor.com/cli — required to run scans."
  fi

  if command -v python3 >/dev/null 2>&1; then
    ok "Python 3 found: $(python3 --version 2>&1)"
  else
    err "Python 3 not found. Required for reports, Feishu notifications, dashboard, and project registry."
    printf '  Install with: xcode-select --install   (or: brew install python3)\n'
  fi

  if command -v git >/dev/null 2>&1; then
    ok "git found: $(git --version)"
  else
    err "git not found. Required for worktree-based scanning."
  fi

  local webhook_source=""
  local workspace=""
  workspace="$( (set +e; resolve_command_workspace >/dev/null 2>&1; printf '%s' "${RESOLVED_WORKSPACE}") )" || true
  if [[ -n "${workspace}" ]]; then
    load_env_file_if_present "${workspace}/.env.common"
    load_env_file_if_present "${workspace}/.env.local"
  fi

  if command -v gh >/dev/null 2>&1; then
    local gh_host=""
    if [[ -n "${workspace}" ]] && command -v python3 >/dev/null 2>&1 && [[ -f "${LUMEN_HOME}/lib/scripts/github_auth_context.py" ]]; then
      gh_host="$(python3 "${LUMEN_HOME}/lib/scripts/github_auth_context.py" detect-host "${workspace}" 2>/dev/null || true)"
    fi
    if [[ -n "${GH_TOKEN:-${GITHUB_TOKEN:-}}" ]] && { [[ -z "${gh_host}" ]] || gh auth status -h "${gh_host}" >/dev/null 2>&1; }; then
      ok "GitHub CLI (gh) token is available from .env.local${gh_host:+ for ${gh_host}}."
    elif [[ -n "${gh_host}" ]] && gh auth status -h "${gh_host}" >/dev/null 2>&1; then
      ok "GitHub CLI (gh) authenticated for ${gh_host}."
    elif gh auth status >/dev/null 2>&1; then
      ok "GitHub CLI (gh) found and authenticated."
    else
      warn "GitHub CLI (gh) is not authenticated${gh_host:+ for ${gh_host}}."
      if [[ -n "${gh_host}" ]]; then
        printf '  Interactive: gh auth login -h %s\n' "${gh_host}"
      else
        printf '  Interactive: gh auth login\n'
      fi
      printf '  Scheduled scans: lumen config set-gh-token <token> --host %s --project <slug>\n' "${gh_host:-mercedes-benz.ghe.com}"
    fi
  else
    warn "GitHub CLI (gh) not found. Scans will run, but automated PR creation will be skipped."
  fi

  if [[ -n "${FEISHU_WEBHOOK_URL:-}" ]]; then
    webhook_source="the current shell environment"
  elif [[ -n "${workspace}" ]]; then
    if [[ -n "${FEISHU_WEBHOOK_URL:-}" ]]; then
      webhook_source="${workspace}/.env.local"
    fi
  fi

  if [[ -n "${webhook_source}" ]]; then
    ok "FEISHU_WEBHOOK_URL is set (from ${webhook_source})."
  else
    warn "FEISHU_WEBHOOK_URL is not set for this workspace."
    printf '  Set it with: lumen config set-webhook <url> --project <slug>\n'
    printf '  Or add FEISHU_WEBHOOK_URL to <workspace>/.env.local\n'
  fi

  local chrome_path=""
  for candidate in \
    "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
    "/Applications/Chromium.app/Contents/MacOS/Chromium" \
    "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge"; do
    if [[ -x "${candidate}" ]]; then
      chrome_path="${candidate}"
      break
    fi
  done
  if [[ -n "${chrome_path}" ]]; then
    ok "PDF export available via system browser (Chrome headless, no extra install)."
  else
    warn "No system browser found for PDF export. HTML reports still work; install Chrome for PDF."
  fi

  if command -v twg >/dev/null 2>&1; then
    ok "Atlassian TWG CLI (twg) found: $(command -v twg)"
    if [[ -f "${HOME}/.config/twg/auth.conf" ]]; then
      ok "twg authentication config found (~/.config/twg/auth.conf)."
    else
      warn "twg is installed but not authenticated. Run 'twg login' to enable Jira sync."
      printf '  Docs: https://developer.atlassian.com/cloud/twg-cli/\n'
    fi
  else
    warn "Atlassian TWG CLI (twg) not found. Jira issue sync will be skipped."
    printf '  Install: bash <(curl -fsSL https://teamwork-graph.atlassian.com/cli/install)\n'
  fi

  if [[ -n "${workspace}" && -f "${workspace}/config/common.json" ]] && command -v python3 >/dev/null 2>&1; then
    local jira_enabled=""
    jira_enabled="$(python3 -c "import json
try:
    with open('${workspace}/config/common.json') as f:
        print(json.load(f).get('notifications', {}).get('jira', {}).get('enabled', False))
except Exception:
    print('')" 2>/dev/null)"
    if [[ "${jira_enabled}" == "True" ]]; then
      ok "Jira sync is enabled in ${workspace}/config/common.json."
    fi
  fi

  if command -v crontab >/dev/null 2>&1 && crontab -l 2>/dev/null | grep -q '# lumen-schedule:'; then
    if [[ -n "${workspace}" ]]; then
      load_env_file_if_present "${workspace}/.env.local"
    fi
    if [[ -n "${CURSOR_API_KEY:-}" ]]; then
      ok "CURSOR_API_KEY is set for scheduled scans."
    else
      warn "CURSOR_API_KEY is not set. Scheduled scans will fail under cron."
      printf '  Add it during lumen init or: lumen config set-cursor-api-key <key> --project <slug>\n'
    fi
    if [[ -n "${GH_TOKEN:-${GITHUB_TOKEN:-}}" ]]; then
      ok "GH_TOKEN is set for scheduled PR creation."
    else
      warn "GH_TOKEN is not set. Scheduled scans can review code but will skip automated PR creation."
      printf '  Add: lumen config set-gh-token <token> --host <github-host> --project <slug>\n'
    fi
  elif [[ -n "${workspace}" ]]; then
    load_env_file_if_present "${workspace}/.env.local"
    if [[ -n "${CURSOR_API_KEY:-}" ]]; then
      ok "CURSOR_API_KEY is set in ${workspace}/.env.local."
    fi
  fi

  if [[ -n "${workspace}" && -f "${LUMEN_LIB_DIR}/visual_delivery.py" ]] && command -v python3 >/dev/null 2>&1; then
    printf '\n%sVisual Delivery readiness%s\n' "${BOLD}" "${RESET}"
    python3 "${LUMEN_LIB_DIR}/visual_delivery.py" doctor --workspace-root "${workspace}" || true
  fi

  if [[ -n "${workspace}" && -f "${LUMEN_LIB_DIR}/agent_trace.py" ]] && command -v python3 >/dev/null 2>&1; then
    printf '\n%sAgent Trace readiness%s\n' "${BOLD}" "${RESET}"
    python3 "${LUMEN_LIB_DIR}/agent_trace.py" doctor --workspace-root "${workspace}" || true
  fi
}

write_workspace_webhook() {
  set_env_local_var "$1" "FEISHU_WEBHOOK_URL" "$2"
}

write_workspace_cursor_api_key() {
  set_env_local_var "$1" "CURSOR_API_KEY" "$2"
}

write_workspace_gh_token() {
  local workspace="$1"
  local token="$2"
  local host="$3"
  set_env_local_var "${workspace}" "GH_TOKEN" "${token}"
  if [[ -n "${host}" ]]; then
    set_env_local_var "${workspace}" "GH_HOST" "${host}"
  fi
}

ensure_env_local_file() {
  local workspace="$1"
  local env_file="${workspace}/.env.local"
  local example_file="${workspace}/.env.local.example"
  if [[ -f "${env_file}" ]]; then
    return 0
  fi
  if [[ -f "${example_file}" ]]; then
    cp "${example_file}" "${env_file}"
  else
    printf '# Local secrets and machine-specific values.\n# .env.local must never be committed.\n\n' > "${env_file}"
  fi
}

set_env_local_var() {
  local workspace="$1"
  local key="$2"
  local value="$3"
  local env_file="${workspace}/.env.local"
  ensure_env_local_file "${workspace}"
  if grep -q "^${key}=" "${env_file}" 2>/dev/null; then
    sed -i.bak "s#^${key}=.*#${key}=\"$(sed_escape_replacement "${value}")\"#" "${env_file}"
    rm -f "${env_file}.bak"
  else
    printf '%s="%s"\n' "${key}" "$(sed_escape_replacement "${value}")" >> "${env_file}"
  fi
}

write_workspace_jira() {
  local workspace="$1"
  local mode="$2"
  local project_key="$3"
  local board_id="$4"
  local assign_sprint="$5"
  local board_id_set="${6:-0}"
  local config_py="${LUMEN_LIB_DIR}/workspace_config.py"
  local args=(set-jira "${workspace}")

  case "${mode}" in
    enable)
      args+=(--enable --project-key "${project_key}")
      if [[ "${board_id_set}" == "1" ]]; then
        args+=(--board-id "${board_id}")
      elif [[ -n "${board_id}" ]]; then
        args+=(--board-id "${board_id}")
      fi
      if [[ "${assign_sprint}" == "0" ]]; then
        args+=(--no-active-sprint)
      else
        args+=(--assign-active-sprint)
      fi
      ;;
    disable)
      args+=(--disable)
      ;;
    update)
      [[ -n "${project_key}" ]] && args+=(--project-key "${project_key}")
      if [[ "${board_id_set}" == "1" ]]; then
        args+=(--board-id "${board_id}")
      elif [[ -n "${board_id}" ]]; then
        args+=(--board-id "${board_id}")
      fi
      if [[ "${assign_sprint}" == "0" ]]; then
        args+=(--no-active-sprint)
      elif [[ "${assign_sprint}" == "1" ]]; then
        args+=(--assign-active-sprint)
      fi
      ;;
  esac

  command -v python3 >/dev/null 2>&1 || { err "Python 3 is required for Jira config."; return 1; }
  if [[ ! -f "${config_py}" ]]; then
    err "Config helper not found: ${config_py}"
    return 1
  fi
  python3 "${config_py}" "${args[@]}"
}

cmd_config() {
  local sub="${1:-}"
  shift || true
  local config_py="${LUMEN_LIB_DIR}/workspace_config.py"

  case "${sub}" in
    set-webhook)
      local url="" filtered_args=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project|-p|--workspace)
            filtered_args+=("$1" "${2:-}")
            shift 2
            ;;
          --no-open)
            filtered_args+=("$1")
            shift
            ;;
          --*)
            err "Unknown option: $1"
            exit 1
            ;;
          *)
            if [[ -z "${url}" ]]; then
              url="$1"
            else
              err "Unexpected argument: $1"
              exit 1
            fi
            shift
            ;;
        esac
      done
      if [[ -z "${url}" ]]; then
        err "Usage: lumen config set-webhook <url> [--project <slug>]"
        exit 1
      fi
      resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"
      write_workspace_webhook "${RESOLVED_WORKSPACE}" "${url}"
      ok "Saved FEISHU_WEBHOOK_URL to ${RESOLVED_WORKSPACE}/.env.local"
      ;;
    set-cursor-api-key)
      local api_key="" filtered_args=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project|-p|--workspace)
            filtered_args+=("$1" "${2:-}")
            shift 2
            ;;
          --no-open)
            filtered_args+=("$1")
            shift
            ;;
          --*)
            err "Unknown option: $1"
            exit 1
            ;;
          *)
            if [[ -z "${api_key}" ]]; then
              api_key="$1"
            else
              err "Unexpected argument: $1"
              exit 1
            fi
            shift
            ;;
        esac
      done
      if [[ -z "${api_key}" ]]; then
        err "Usage: lumen config set-cursor-api-key <key> [--project <slug>]"
        exit 1
      fi
      resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"
      write_workspace_cursor_api_key "${RESOLVED_WORKSPACE}" "${api_key}"
      ok "Saved CURSOR_API_KEY to ${RESOLVED_WORKSPACE}/.env.local"
      ;;
    set-gh-token)
      local token="" host="" filtered_args=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project|-p|--workspace)
            filtered_args+=("$1" "${2:-}")
            shift 2
            ;;
          --no-open)
            filtered_args+=("$1")
            shift
            ;;
          --host)
            host="${2:-}"
            shift 2
            ;;
          --*)
            err "Unknown option: $1"
            exit 1
            ;;
          *)
            if [[ -z "${token}" ]]; then
              token="$1"
            else
              err "Unexpected argument: $1"
              exit 1
            fi
            shift
            ;;
        esac
      done
      if [[ -z "${token}" ]]; then
        err "Usage: lumen config set-gh-token <token> [--host <github-host>] [--project <slug>]"
        exit 1
      fi
      resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"
      if [[ -z "${host}" ]] && command -v python3 >/dev/null 2>&1 && [[ -f "${LUMEN_HOME}/lib/scripts/github_auth_context.py" ]]; then
        host="$(python3 "${LUMEN_HOME}/lib/scripts/github_auth_context.py" detect-host "${RESOLVED_WORKSPACE}" 2>/dev/null || true)"
      fi
      write_workspace_gh_token "${RESOLVED_WORKSPACE}" "${token}" "${host}"
      ok "Saved GH_TOKEN to ${RESOLVED_WORKSPACE}/.env.local"
      if [[ -n "${host}" ]]; then
        ok "Saved GH_HOST=${host}"
      fi
      ;;
    set-scan-window)
      local days="" filtered_args=() arg
      for arg in "$@"; do
        case "${arg}" in
          --project|-p|--workspace|--no-open) filtered_args+=("${arg}") ;;
          --*) err "Unknown option: ${arg}"; exit 1 ;;
          *)
            if [[ -z "${days}" ]]; then
              days="${arg}"
            else
              err "Unexpected argument: ${arg}"
              exit 1
            fi
            ;;
        esac
      done
      if [[ -z "${days}" ]]; then
        err "Usage: lumen config set-scan-window <days> [--project <slug>]"
        exit 1
      fi
      if ! [[ "${days}" =~ ^[0-9]+$ ]]; then
        err "Scan window must be a positive integer (got: ${days})"
        exit 1
      fi
      resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"
      if [[ ! -f "${config_py}" ]]; then
        err "Config helper not found: ${config_py}"
        exit 1
      fi
      command -v python3 >/dev/null 2>&1 || { err "Python 3 is required for lumen config."; exit 1; }
      if ! python3 "${config_py}" set-scan-window "${RESOLVED_WORKSPACE}" "${days}"; then
        exit 1
      fi
      ok "Saved execution.scan_window_days=${days} to ${RESOLVED_WORKSPACE}/config/common.json"
      ;;
    set-visual-auth)
      local repository="" credential="" filtered_args=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project|-p|--workspace)
            filtered_args+=("$1" "${2:-}")
            shift 2
            ;;
          --no-open)
            filtered_args+=("$1")
            shift
            ;;
          --*)
            err "Unknown option: $1"
            exit 1
            ;;
          *)
            if [[ -z "${repository}" ]]; then
              repository="$1"
            elif [[ -z "${credential}" ]]; then
              credential="$1"
            else
              err "Unexpected argument: $1"
              exit 1
            fi
            shift
            ;;
        esac
      done
      if [[ -z "${repository}" || -z "${credential}" ]]; then
        err "Usage: lumen config set-visual-auth <repository> <credential> [--project <slug>]"
        exit 1
      fi
      resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"
      if [[ ! -f "${config_py}" ]]; then
        err "Config helper not found: ${config_py}"
        exit 1
      fi
      command -v python3 >/dev/null 2>&1 || { err "Python 3 is required for lumen config."; exit 1; }
      if ! python3 "${config_py}" set-visual-auth "${RESOLVED_WORKSPACE}" "${repository}" "${credential}"; then
        exit 1
      fi
      ok "Saved visual auth credential for ${repository}"
      ;;
    set-jira)
      local enable_flag="" disable_flag="" project_key="" board_id=""
      local assign_sprint="" board_id_set="0" interactive="0" filtered_args=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --enable) enable_flag="1"; shift ;;
          --disable) disable_flag="1"; shift ;;
          --project-key)
            project_key="${2:-}"
            shift 2
            ;;
          --board-id)
            board_id="${2:-}"
            board_id_set="1"
            shift 2
            ;;
          --no-active-sprint) assign_sprint="0"; shift ;;
          --assign-active-sprint) assign_sprint="1"; shift ;;
          --project|-p|--workspace|--no-open) filtered_args+=("$1"); shift ;;
          --*) err "Unknown option: $1"; exit 1 ;;
          *) filtered_args+=("$1"); shift ;;
        esac
      done
      resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"

      if [[ -z "${enable_flag}" && -z "${disable_flag}" && -z "${project_key}" && "${board_id_set}" == "0" && -z "${assign_sprint}" && -t 0 && -t 1 ]]; then
        interactive="1"
      fi

      if [[ "${interactive}" == "1" ]]; then
        if prompt_yn "Enable Jira Bug cards for High/Medium findings after each scan?" "n"; then
          enable_flag="1"
          if prompt_yn "Assign new bugs to the active sprint?" "y"; then
            assign_sprint="1"
          else
            assign_sprint="0"
          fi
          pick_jira_project_with_twg "MBPAS" "${assign_sprint}"
          project_key="${JIRA_PROJECT_KEY}"
          board_id="${JIRA_BOARD_ID}"
          board_id_set="${JIRA_BOARD_ID_SET}"
        else
          disable_flag="1"
        fi
      fi

      if [[ -n "${enable_flag}" && -n "${disable_flag}" ]]; then
        err "Use either --enable or --disable, not both."
        exit 1
      fi
      if [[ -z "${enable_flag}" && -z "${disable_flag}" && -z "${project_key}" && "${board_id_set}" == "0" && -z "${assign_sprint}" ]]; then
        err "Usage: lumen config set-jira [--enable|--disable] [--project-key <key>] [--board-id <id>] [--project <slug>]"
        err "Run without flags in a terminal for interactive setup."
        exit 1
      fi

      if [[ "${enable_flag}" == "1" ]]; then
        if [[ -z "${project_key}" ]]; then
          err "Jira project key is required. Use --project-key <key> or run interactively."
          exit 1
        fi
        if [[ -z "${assign_sprint}" ]]; then
          assign_sprint="1"
        fi
        if ! write_workspace_jira "${RESOLVED_WORKSPACE}" "enable" "${project_key}" "${board_id}" "${assign_sprint}" "${board_id_set}"; then
          exit 1
        fi
        ok "Saved Jira settings to ${RESOLVED_WORKSPACE}/config/common.json"
      elif [[ "${disable_flag}" == "1" ]]; then
        if ! write_workspace_jira "${RESOLVED_WORKSPACE}" "disable" "" "" "1" "0"; then
          exit 1
        fi
        ok "Disabled Jira sync in ${RESOLVED_WORKSPACE}/config/common.json"
      else
        if ! write_workspace_jira "${RESOLVED_WORKSPACE}" "update" "${project_key}" "${board_id}" "${assign_sprint}" "${board_id_set}"; then
          exit 1
        fi
        ok "Updated Jira settings in ${RESOLVED_WORKSPACE}/config/common.json"
      fi
      ;;
    show)
      resolve_command_workspace "$@"
      if [[ -f "${config_py}" ]] && command -v python3 >/dev/null 2>&1; then
        python3 "${config_py}" show "${RESOLVED_WORKSPACE}"
        return $?
      fi
      local env_file="${RESOLVED_WORKSPACE}/.env.local"
      if [[ -f "${env_file}" ]]; then
        printf 'Workspace config: %s\n\n' "${env_file}"
        grep '^FEISHU_WEBHOOK_URL=' "${env_file}" || printf 'FEISHU_WEBHOOK_URL is not set in this workspace.\n'
      else
        printf 'No .env.local found at %s\n' "${env_file}"
        printf 'Run: lumen config set-webhook <url> --project <slug>\n'
      fi
      ;;
    unset-webhook)
      resolve_command_workspace "$@"
      local env_file="${RESOLVED_WORKSPACE}/.env.local"
      if [[ -f "${env_file}" ]]; then
        sed -i.bak '/^FEISHU_WEBHOOK_URL=/d' "${env_file}"
        rm -f "${env_file}.bak"
        ok "Removed FEISHU_WEBHOOK_URL from ${env_file}"
      else
        warn "No .env.local found for this workspace."
      fi
      ;;
    unset-cursor-api-key)
      resolve_command_workspace "$@"
      local env_file="${RESOLVED_WORKSPACE}/.env.local"
      if [[ -f "${env_file}" ]]; then
        sed -i.bak '/^CURSOR_API_KEY=/d' "${env_file}"
        rm -f "${env_file}.bak"
        ok "Removed CURSOR_API_KEY from ${env_file}"
      else
        warn "No .env.local found for this workspace."
      fi
      ;;
    *)
      printf 'Usage:\n'
      printf '  lumen config set-webhook <url> [--project <slug>]\n'
      printf '  lumen config set-cursor-api-key <key> [--project <slug>]\n'
      printf '  lumen config set-gh-token <token> [--host <github-host>] [--project <slug>]\n'
      printf '  lumen config set-scan-window <days> [--project <slug>]\n'
      printf '  lumen config set-visual-auth <repository> <credential> [--project <slug>]\n'
      printf '  lumen config set-jira [--enable|--disable] [--project-key <key>] [--board-id <id>] [--project <slug>]\n'
      printf '  lumen config show [--project <slug>]\n'
      printf '  lumen config unset-webhook [--project <slug>]\n'
      printf '  lumen config unset-cursor-api-key [--project <slug>]\n'
      exit 1
      ;;
  esac
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "${value}"
}

sed_escape_replacement() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//&/\\&}"
  value="${value//\//\\/}"
  printf '%s' "${value}"
}

prompt() {
  local message="$1"
  local default_value="${2:-}"
  local answer=""
  if [[ -n "${default_value}" ]]; then
    read -r -p "${message} [${default_value}]: " answer || true
  else
    read -r -p "${message}: " answer || true
  fi
  if [[ -z "${answer}" ]]; then
    answer="${default_value}"
  fi
  printf '%s' "${answer}"
}

prompt_secret() {
  local message="$1"
  local answer=""
  read -r -s -p "${message} (input hidden, Enter to skip): " answer || true
  printf '\n' >&2
  printf '%s' "${answer}"
}

prompt_yn() {
  local message="$1"
  local default_value="${2:-y}"
  local hint="y/N"
  [[ "${default_value}" == "y" ]] && hint="Y/n"
  local answer=""
  read -r -p "${message} [${hint}]: " answer || true
  answer="${answer:-${default_value}}"
  [[ "${answer}" =~ ^[Yy] ]]
}

prompt_menu() {
  local message="$1"
  shift
  local options=("$@")
  local i
  printf '%s\n' "${message}" >&2
  for i in "${!options[@]}"; do
    printf '  %d) %s\n' "$((i + 1))" "${options[$i]}" >&2
  done
  local choice=""
  read -r -p "Choose [1-${#options[@]}, default 1]: " choice || true
  if [[ -z "${choice}" ]]; then
    choice=1
  fi
  if ! [[ "${choice}" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#options[@]} )); then
    choice=1
  fi
  printf '%s' "${options[$((choice - 1))]}"
}

pick_jira_project_with_twg() {
  local default_key="${1:-MBPAS}"
  local assign_sprint="${2:-1}"
  local select_script="${LUMEN_LIB_DIR}/select_jira_space.py"
  local discover_script="${LUMEN_LIB_DIR}/discover_jira_spaces.py"
  local select_tmp select_exit spaces_json space_count selection chosen_json assign_args=()

  JIRA_PROJECT_KEY=""
  JIRA_BOARD_ID=""
  JIRA_BOARD_ID_SET="0"

  if [[ "${assign_sprint}" == "1" ]]; then
    assign_args=(--assign-active-sprint)
  fi

  if ! command -v twg >/dev/null 2>&1; then
    warn "twg CLI not found. Install it and run: twg login"
    JIRA_PROJECT_KEY="$(prompt "Jira project key" "${default_key}")"
    JIRA_BOARD_ID="$(prompt "Jira board ID (leave blank to auto-detect)" "")"
    [[ -n "${JIRA_BOARD_ID}" ]] && JIRA_BOARD_ID_SET="1"
    return 0
  fi

  if [[ ! -f "${HOME}/.config/twg/auth.conf" ]]; then
    warn "twg is not authenticated. Run: twg login"
    JIRA_PROJECT_KEY="$(prompt "Jira project key" "${default_key}")"
    JIRA_BOARD_ID="$(prompt "Jira board ID (leave blank to auto-detect)" "")"
    [[ -n "${JIRA_BOARD_ID}" ]] && JIRA_BOARD_ID_SET="1"
    return 0
  fi

  if [[ ! -f "${select_script}" ]] || ! command -v python3 >/dev/null 2>&1; then
    warn "Jira project picker is unavailable. Falling back to manual entry."
    JIRA_PROJECT_KEY="$(prompt "Jira project key" "${default_key}")"
    JIRA_BOARD_ID="$(prompt "Jira board ID (leave blank to auto-detect)" "")"
    [[ -n "${JIRA_BOARD_ID}" ]] && JIRA_BOARD_ID_SET="1"
    return 0
  fi

  if [[ -t 0 && -t 1 ]]; then
    select_tmp="$(mktemp)"
    set +e
    python3 "${select_script}" --default-key "${default_key}" "${assign_args[@]}" --output "${select_tmp}"
    select_exit=$?
    set -e
    if [[ "${select_exit}" == "0" ]]; then
      JIRA_PROJECT_KEY="$(python3 -c "import json; print(json.load(open('${select_tmp}')).get('project_key',''))")"
      JIRA_BOARD_ID="$(python3 -c "import json; print(json.load(open('${select_tmp}')).get('board_id',''))")"
      if [[ -n "${JIRA_BOARD_ID}" ]]; then
        JIRA_BOARD_ID_SET="1"
      fi
      rm -f "${select_tmp}"
      ok "Selected Jira project ${JIRA_PROJECT_KEY}."
      return 0
    fi
    rm -f "${select_tmp:-}"
    if [[ "${select_exit}" == "130" ]]; then
      printf '\nAborted.\n'
      exit 130
    fi
  fi

  if [[ ! -f "${discover_script}" ]]; then
    JIRA_PROJECT_KEY="$(prompt "Jira project key" "${default_key}")"
    JIRA_BOARD_ID="$(prompt "Jira board ID (leave blank to auto-detect)" "")"
    [[ -n "${JIRA_BOARD_ID}" ]] && JIRA_BOARD_ID_SET="1"
    return 0
  fi

  spaces_json="$(python3 "${discover_script}" list 2>/dev/null || true)"
  space_count="$(json_array_length "${spaces_json}")"
  if [[ "${space_count}" == "0" ]]; then
    warn "Could not load Jira project spaces from twg."
    JIRA_PROJECT_KEY="$(prompt "Jira project key" "${default_key}")"
    JIRA_BOARD_ID="$(prompt "Jira board ID (leave blank to auto-detect)" "")"
    [[ -n "${JIRA_BOARD_ID}" ]] && JIRA_BOARD_ID_SET="1"
    return 0
  fi

  printf '\n%sJira project spaces%s\n' "${BOLD}" "${RESET}"
  python3 -c "import json,sys
for index, space in enumerate(json.loads(sys.argv[1]), start=1):
    print(f'  {index}) {space[\"key\"]} — {space[\"name\"]}')" "${spaces_json}"
  printf '\nEnter a project number or key, or type %smanual%s to enter a key:\n' "${BOLD}" "${RESET}"
  while true; do
    read -r -p "Selection: " selection || true
    [[ -n "${selection}" ]] && break
    printf 'Select a Jira project.\n'
  done

  if [[ "${selection}" == "manual" ]]; then
    JIRA_PROJECT_KEY="$(prompt "Jira project key" "${default_key}")"
    JIRA_BOARD_ID="$(prompt "Jira board ID (leave blank to auto-detect)" "")"
    [[ -n "${JIRA_BOARD_ID}" ]] && JIRA_BOARD_ID_SET="1"
    return 0
  fi

  if ! chosen_json="$(python3 "${discover_script}" select "${selection}" 2>/dev/null)"; then
    err "Invalid Jira project selection: ${selection}"
    exit 1
  fi

  JIRA_PROJECT_KEY="$(python3 -c "import json,sys; print(json.loads(sys.argv[1])[0]['key'])" "${chosen_json}")"
  if [[ "${assign_sprint}" == "1" && -f "${LUMEN_LIB_DIR}/jira_spaces.py" ]]; then
    JIRA_BOARD_ID="$(python3 -c "import sys
sys.path.insert(0, '${LUMEN_LIB_DIR}')
from jira_spaces import choose_default_board, list_jira_boards
boards = list_jira_boards('${JIRA_PROJECT_KEY}')
print(choose_default_board(boards) or '')" 2>/dev/null || true)"
    [[ -n "${JIRA_BOARD_ID}" ]] && JIRA_BOARD_ID_SET="1"
  fi
  ok "Selected Jira project ${JIRA_PROJECT_KEY}."
  return 0
}

collect_jira_settings_interactively() {
  local default_key="${1:-MBPAS}"

  JIRA_PROJECT_KEY=""
  JIRA_BOARD_ID=""
  JIRA_BOARD_ID_SET="0"
  JIRA_ASSIGN_SPRINT="1"

  if ! prompt_yn "Create Jira Bug cards for High/Medium findings after each scan?" "n"; then
    return 1
  fi

  if prompt_yn "Assign new bugs to the active sprint?" "y"; then
    JIRA_ASSIGN_SPRINT="1"
  else
    JIRA_ASSIGN_SPRINT="0"
  fi

  pick_jira_project_with_twg "${default_key}" "${JIRA_ASSIGN_SPRINT}"
  return 0
}

REPOS=()

discover_repos_json() {
  local workspace_root="$1"
  python3 "${LUMEN_LIB_DIR}/discover_repos.py" list "${workspace_root}"
}

append_repo_entry() {
  local name="$1"
  local path="$2"
  local branch="$3"
  local profile="$4"
  local allow_fix="$5"
  local allow_pr="$6"
  REPOS+=("{\"name\":\"$(json_escape "${name}")\",\"path\":\"$(json_escape "${path}")\",\"default_branch\":\"$(json_escape "${branch}")\",\"runtime_profile\":\"$(json_escape "${profile}")\",\"validation_commands\":[],\"allow_auto_fix\":${allow_fix},\"allow_pr\":${allow_pr}}")
}

collect_repository_manually() {
  local workspace_root="$1"
  local allow_fix="$2"
  local allow_pr="$3"
  local name path clone_url branch profile

  name="$(prompt "Repository name" "")"
  [[ -z "${name}" ]] && return 1

  while true; do
    clone_url="$(prompt "Git clone URL (leave blank if it is already cloned locally)" "")"
    if [[ -n "${clone_url}" ]]; then
      if [[ "${clone_url}" != *"/"* && "${clone_url}" != *":"* ]]; then
        warn "That doesn't look like a git URL: ${clone_url}"
        if ! prompt_yn "Try entering the URL again?" "y"; then
          printf 'Cancelled adding repository "%s".\n' "${name}"
          return 1
        fi
        continue
      fi

      path="$(prompt "Local directory to clone into" "${workspace_root}/${name}")"
      if [[ -d "${path}/.git" ]]; then
        warn "Directory already looks like a git repo, skipping clone: ${path}"
        break
      fi

      printf 'Cloning %s into %s ...\n' "${clone_url}" "${path}"
      if git clone "${clone_url}" "${path}"; then
        ok "Cloned ${name}."
        break
      fi

      warn "Clone failed for: ${clone_url}"
      if ! prompt_yn "Try again with a different URL?" "y"; then
        printf 'Cancelled adding repository "%s".\n' "${name}"
        return 1
      fi
    else
      path="$(prompt "Local path to the existing repository" "${workspace_root}/${name}")"
      if [[ -d "${path}/.git" ]]; then
        break
      fi
      warn "No git repository found at: ${path}"
      if ! prompt_yn "Try a different path?" "y"; then
        printf 'Cancelled adding repository "%s".\n' "${name}"
        return 1
      fi
    fi
  done

  branch="main"
  if [[ -d "${path}/.git" ]]; then
    branch="$(git -C "${path}" symbolic-ref --short HEAD 2>/dev/null || echo main)"
  fi
  branch="$(prompt "Default branch" "${branch}")"
  profile="$(prompt_menu "Runtime profile" \
    "local-java-review-only" "local-react-native-review-only" "local-php-review-only" "local-generic-review-only")"
  append_repo_entry "${name}" "${path}" "${branch}" "${profile}" "${allow_fix}" "${allow_pr}"
  ok "Added ${name}."
  return 0
}

collect_repositories_interactively() {
  local workspace_root="$1"
  local discovered_json repo_count selection selected_json allow_fix allow_pr select_tmp select_exit

  printf '\n%sRepositories to scan%s\n' "${BOLD}" "${RESET}"

  if ! command -v python3 >/dev/null 2>&1 || [[ ! -f "${LUMEN_LIB_DIR}/discover_repos.py" ]]; then
    warn "Repository discovery requires Python 3. Falling back to manual entry."
    while collect_repository_manually "${workspace_root}" "true" "true"; do
      if ! prompt_yn "Add another repository manually?" "n"; then
        break
      fi
    done
    return 0
  fi

  discovered_json="$(discover_repos_json "${workspace_root}")"
  repo_count="$(json_array_length "${discovered_json}")"

  if [[ "${repo_count}" == "0" ]]; then
    printf 'No git repositories found under %s\n' "${workspace_root}"
    printf 'You can add repositories manually instead.\n\n'
    while collect_repository_manually "${workspace_root}" "true" "true"; do
      if ! prompt_yn "Add another repository manually?" "n"; then
        break
      fi
    done
    return 0
  fi

  printf 'Found %s git repositor%s under %s\n' "${repo_count}" "$([ "${repo_count}" = "1" ] && echo y || echo ies)" "${workspace_root}"

  selected_json=""
  if [[ -t 0 && -t 1 && -f "${LUMEN_LIB_DIR}/select_repos.py" ]]; then
    select_tmp="$(mktemp)"
    set +e
    python3 "${LUMEN_LIB_DIR}/select_repos.py" "${workspace_root}" --output "${select_tmp}"
    select_exit=$?
    set -e
  else
    select_exit=1
  fi

  if [[ "${select_exit}" == "2" ]]; then
    rm -f "${select_tmp:-}"
    printf '\n%sAdd repository manually%s\n' "${BOLD}" "${RESET}"
    collect_repository_manually "${workspace_root}" "true" "true"
    return 0
  fi

  if [[ "${select_exit}" == "130" ]]; then
    rm -f "${select_tmp:-}"
    printf '\nAborted.\n'
    exit 130
  fi

  if [[ "${select_exit}" != "0" ]]; then
    rm -f "${select_tmp:-}"
    printf '\nEnter repository numbers to scan (comma-separated), %sall%s, or %smanual%s to add by URL:\n' "${BOLD}" "${RESET}" "${BOLD}" "${RESET}"
    selection=""
    while true; do
      read -r -p "Selection: " selection || true
      if [[ -n "${selection}" ]]; then
        break
      fi
      printf 'Select at least one repository, or type "all".\n'
    done

    if [[ "${selection}" == "+" || "${selection}" == "manual" ]]; then
      collect_repository_manually "${workspace_root}" "true" "true"
      return 0
    fi

    if ! selected_json="$(python3 "${LUMEN_LIB_DIR}/discover_repos.py" select "${workspace_root}" "${selection}" 2>/dev/null)"; then
      err "Invalid selection: ${selection}"
      exit 1
    fi
  else
    selected_json="$(cat "${select_tmp}")"
    rm -f "${select_tmp}"
    printf '\n'
  fi

  if prompt_yn "Allow automated fix commits for confirmed High findings for all selected repositories?" "y"; then
    allow_fix="true"
  else
    allow_fix="false"
  fi
  if prompt_yn "Allow automated PR creation for confirmed High findings for all selected repositories?" "y"; then
    allow_pr="true"
  else
    allow_pr="false"
  fi

  while IFS= read -r repo_line; do
    local name path branch profile
    name="$(json_get "${repo_line}" name)"
    path="$(json_get "${repo_line}" path)"
    branch="$(json_get "${repo_line}" default_branch)"
    profile="$(json_get "${repo_line}" runtime_profile)"
    append_repo_entry "${name}" "${path}" "${branch}" "${profile}" "${allow_fix}" "${allow_pr}"
    ok "Selected ${name}"
  done < <(json_array_items "${selected_json}")

  printf '\n'
  if prompt_yn "Add another repository manually?" "n"; then
    collect_repository_manually "${workspace_root}" "${allow_fix}" "${allow_pr}"
  fi

  return 0
}

is_lumen_workspace_configured() {
  local lumen_dir="$1"
  if [[ ! -f "${lumen_dir}/config/common.json" || ! -f "${lumen_dir}/config/repos.json" ]]; then
    return 1
  fi
  python3 "${LUMEN_LIB_DIR}/workspace_configured.py" "${lumen_dir}"
}

remove_lumen_workspace() {
  local lumen_dir="$1"
  rm -rf "${lumen_dir}"
}

maybe_replace_existing_workspace() {
  local lumen_dir="$1"
  local assume_yes="$2"
  local force="$3"
  local interactive="0"

  if [[ "${assume_yes}" == "0" && -t 0 && -t 1 ]]; then
    interactive="1"
  fi

  if is_lumen_workspace_configured "${lumen_dir}"; then
    if [[ "${force}" != "1" ]]; then
      warn "A Lumen workspace already exists at: ${lumen_dir}"
      printf 'Edit config there, or run %slumen init --force%s to replace it.\n' "${BOLD}" "${RESET}"
      return 1
    fi
    warn "Replacing existing workspace at: ${lumen_dir}"
    if [[ "${interactive}" == "1" ]]; then
      if ! prompt_yn "Delete the existing workspace and all scan history inside it?" "n"; then
        printf 'Aborted.\n'
        return 1
      fi
    fi
  else
    warn "Incomplete Lumen workspace found at: ${lumen_dir} (previous init was interrupted)."
    if [[ "${interactive}" == "1" ]]; then
      if ! prompt_yn "Remove it and run init again?" "y"; then
        printf 'Aborted. Delete %s manually to re-run init.\n' "${lumen_dir}"
        return 1
      fi
    else
      printf 'Removing incomplete workspace and starting again.\n'
    fi
  fi

  remove_lumen_workspace "${lumen_dir}"
  ok "Removed previous workspace."
  return 0
}

cmd_init() {
  local target="."
  local assume_yes="0"
  local force="0"
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --yes|-y) assume_yes="1" ;;
      --force|-f) force="1" ;;
      --*) ;;
      *) target="${arg}" ;;
    esac
  done

  mkdir -p "${target}"
  target="$(cd "${target}" && pwd)"
  local lumen_dir
  lumen_dir="$(default_lumen_workspace_path "${target}")"

  if is_lumen_workspace "${lumen_dir}"; then
    if ! maybe_replace_existing_workspace "${lumen_dir}" "${assume_yes}" "${force}"; then
      return 0
    fi
  fi

  if is_lumen_workspace "${target}"; then
    if [[ "${force}" == "1" ]]; then
      warn "Replacing legacy Lumen workspace at: ${target}"
      remove_lumen_workspace "${target}"
      ok "Removed previous workspace."
    else
      warn "A legacy Lumen workspace already exists at: ${target}"
      printf 'Nothing was overwritten. Consider migrating to %s/ or run %slumen init --force%s.\n' "${LUMEN_DIR_NAME}" "${BOLD}" "${RESET}"
      return 0
    fi
  fi

  printf 'Initializing Lumen workspace at: %s\n' "${target}"
  printf 'Control plane: %s\n' "${lumen_dir}"

  mkdir -p "${lumen_dir}/config" "${lumen_dir}/prompts" "${lumen_dir}/tmp" "${lumen_dir}/worktrees" \
    "${lumen_dir}/reports" "${lumen_dir}/results" "${lumen_dir}/logs" "${lumen_dir}/state"

  cp "${LUMEN_TEMPLATES_DIR}/config/common.json" "${lumen_dir}/config/common.json"
  cp "${LUMEN_TEMPLATES_DIR}/config/repos.example.json" "${lumen_dir}/config/repos.example.json"
  cp "${LUMEN_TEMPLATES_DIR}/config/runtime-profiles.json" "${lumen_dir}/config/runtime-profiles.json"
  sync_prompt_snippets "${lumen_dir}"
  sync_delivery_prompt_snippets "${lumen_dir}"
  cp "${LUMEN_TEMPLATES_DIR}/config/feishu-card-template.json" "${lumen_dir}/config/feishu-card-template.json"
  cp "${LUMEN_TEMPLATES_DIR}/.env.common.example" "${lumen_dir}/.env.common.example"
  cp "${LUMEN_TEMPLATES_DIR}/.env.local.example" "${lumen_dir}/.env.local.example"
  cp "${LUMEN_TEMPLATES_DIR}/.gitignore" "${lumen_dir}/.gitignore"
  cp "${LUMEN_TEMPLATES_DIR}/dashboard.html" "${lumen_dir}/dashboard.html"
  mkdir -p "${lumen_dir}/assets"
  cp "${LUMEN_TEMPLATES_DIR}/assets/lumen-mark.png" "${lumen_dir}/assets/lumen-mark.png"

  touch "${lumen_dir}/tmp/.gitkeep" "${lumen_dir}/worktrees/.gitkeep" "${lumen_dir}/reports/.gitkeep" \
    "${lumen_dir}/results/.gitkeep" "${lumen_dir}/logs/.gitkeep" "${lumen_dir}/state/.gitkeep"

  echo '{"schema_version": "1.0", "issues": []}' > "${lumen_dir}/state/issue-registry.json"

  initialize_integrated_delivery_workspace() {
    local workspace_root="$1"
    local project_name="$2"
    local initializer="${LUMEN_LIB_DIR}/init_delivery_docs.py"
    [[ -f "${initializer}" ]] || { err "Delivery workspace initializer not found: ${initializer}"; return 1; }
    python3 "${initializer}" --target "${workspace_root}" --project-name "${project_name}" --merge --no-example
  }

  sync_integrated_scan_repositories() {
    local workspace_root="$1"
    local sync_py="${LUMEN_LIB_DIR}/sync_workspace_repositories.py"
    [[ -f "${sync_py}" ]] || { err "Workspace repository sync helper not found: ${sync_py}"; return 1; }
    python3 "${sync_py}" "${workspace_root}" >/dev/null
  }

  local interactive="0"
  if [[ "${assume_yes}" == "0" && -t 0 && -t 1 ]]; then
    interactive="1"
  fi

  if [[ "${interactive}" == "0" ]]; then
    initialize_integrated_delivery_workspace "${target}" "$(basename "${target}")" || exit 1
    if [[ ! -f "${lumen_dir}/config/repos.json" ]]; then
      cp "${LUMEN_TEMPLATES_DIR}/config/repos.example.json" "${lumen_dir}/config/repos.json"
    fi
    local noninteractive_common="${lumen_dir}/config/common.json"
    sed -i.bak "s/\"display_name\": \"\"/\"display_name\": \"$(sed_escape_replacement "$(basename "${target}")")\"/" "${noninteractive_common}"
    sed -i.bak "s#\"workspace_root\": \"\"#\"workspace_root\": \"$(sed_escape_replacement "${target}/repos")\"#" "${noninteractive_common}"
    rm -f "${noninteractive_common}.bak"
    sync_integrated_scan_repositories "${target}" || exit 1
    python3 "${LUMEN_LIB_DIR}/visual_delivery.py" detect --workspace-root "${target}" >/dev/null || true
    ok "Workspace created (non-interactive)."
    try_register_project "${lumen_dir}" "$(workspace_display_name "${lumen_dir}")"
    cat <<EOF

Next steps:
  1. Add or clone code repositories under repos/.
  2. Edit ${LUMEN_DIR_NAME}/config/common.json to set project.display_name and execution.model.
  3. Copy ${LUMEN_DIR_NAME}/.env.local.example to ${LUMEN_DIR_NAME}/.env.local and set FEISHU_WEBHOOK_URL and/or CURSOR_API_KEY (required for scheduled scans).
  4. Optional: enable Jira sync with lumen config set-jira --enable --project-key <KEY> --project <slug>
  5. Run: lumen doctor
  6. Run: lumen scan --project <slug>   (see slugs with: lumen list)
  7. Run: lumen delivery run --story <story-key> after a technical plan is approved.
EOF
    return 0
  fi

  printf '\n%sLet'"'"'s configure this workspace.%s\n' "${BOLD}" "${RESET}"

  local display_name workspace_root scan_window model webhook cursor_api_key env_written="0"
  display_name="$(prompt "Project display name" "$(basename "${target}")")"
  initialize_integrated_delivery_workspace "${target}" "${display_name}" || exit 1
  workspace_root="${target}/repos"
  printf 'Code repositories: %s\n' "${workspace_root}"
  scan_window="$(prompt "Scan window in days" "7")"
  model="$(prompt_menu "Cursor model to use for scans" "composer-2.5" "sonnet-4.5" "gpt-5.1-codex" "custom")"
  if [[ "${model}" == "custom" ]]; then
    model="$(prompt "Enter the exact Cursor model name" "composer-2.5")"
  fi
  webhook="$(prompt "Feishu webhook URL (leave blank to skip notifications)" "")"
  cursor_api_key="$(prompt_secret "Cursor API key from Dashboard > API Keys")"

  local jira_enabled="0" jira_project_key="" jira_board_id="" jira_assign_sprint="1" jira_board_id_set="0"
  if collect_jira_settings_interactively "MBPAS"; then
    jira_enabled="1"
    jira_project_key="${JIRA_PROJECT_KEY}"
    jira_board_id="${JIRA_BOARD_ID}"
    jira_board_id_set="${JIRA_BOARD_ID_SET}"
    jira_assign_sprint="${JIRA_ASSIGN_SPRINT}"
  fi

  REPOS=()
  collect_repositories_interactively "${workspace_root}"

  local common_json="${lumen_dir}/config/common.json"
  sed -i.bak "s/\"display_name\": \"\"/\"display_name\": \"$(sed_escape_replacement "${display_name}")\"/" "${common_json}"
  sed -i.bak "s#\"workspace_root\": \"\"#\"workspace_root\": \"$(sed_escape_replacement "${workspace_root}")\"#" "${common_json}"
  sed -i.bak "s/\"model\": \"composer-2.5\"/\"model\": \"$(sed_escape_replacement "${model}")\"/" "${common_json}"
  sed -i.bak "s/\"scan_window_days\": 7/\"scan_window_days\": ${scan_window:-7}/" "${common_json}"
  rm -f "${common_json}.bak"

  {
    printf '{\n  "repositories": ['
    local i
    for i in "${!REPOS[@]}"; do
      [[ "${i}" != "0" ]] && printf ','
      printf '\n    %s' "${REPOS[$i]}"
    done
    if [[ "${#REPOS[@]}" -eq 0 ]]; then
      printf '\n'
    else
      printf '\n  '
    fi
    printf ']\n}\n'
  } > "${lumen_dir}/config/repos.json"

  python3 "${LUMEN_LIB_DIR}/visual_delivery.py" detect --workspace-root "${target}" >/dev/null || \
    warn "Runtime detection failed; edit ${lumen_dir}/config/repos.json and run lumen doctor."

  if [[ -n "${webhook}" ]]; then
    write_workspace_webhook "${lumen_dir}" "${webhook}"
    env_written="1"
  fi
  if [[ -n "${cursor_api_key}" ]]; then
    write_workspace_cursor_api_key "${lumen_dir}" "${cursor_api_key}"
    env_written="1"
  fi
  if [[ "${env_written}" == "1" ]]; then
    ok ".env.local created with your workspace secrets."
  fi

  if [[ "${jira_enabled}" == "1" ]]; then
    if write_workspace_jira "${lumen_dir}" "enable" "${jira_project_key}" "${jira_board_id}" "${jira_assign_sprint}" "${jira_board_id_set}"; then
      ok "Jira sync enabled (project ${jira_project_key})."
    else
      warn "Jira settings were not saved. Run: lumen config set-jira --project <slug>"
    fi
  fi

  ok "Workspace configured with ${#REPOS[@]} repositor$([ "${#REPOS[@]}" = "1" ] && echo y || echo ies)."
  try_register_project "${lumen_dir}" "${display_name}"
  cat <<EOF

Next steps:
  1. Work from this project root. Scan and delivery share repos/, ${LUMEN_DIR_NAME}/, and .env.local.
  2. If Jira sync is enabled, install TWG CLI and run: twg login
  3. For scheduled scans, ensure CURSOR_API_KEY is set in ${LUMEN_DIR_NAME}/.env.local
  4. Run: lumen list
  5. Run: lumen doctor
  6. Run: lumen scan --project <slug>   (see slugs with: lumen list)
  7. Run: lumen delivery run --story <story-key> when a technical plan is approved.
  8. Run: lumen dashboard --project <slug>   (opens the local interactive dashboard)
EOF
}

cmd_list() {
  registry_cmd list
}

remove_schedule_for_slug() {
  local slug="$1"
  if ! command -v crontab >/dev/null 2>&1; then
    return 0
  fi

  local existing filtered marker
  existing="$(read_crontab)"
  filtered="${existing}"
  for marker in "$(schedule_marker "${slug}")" "$(delivery_schedule_marker "${slug}")"; do
    filtered="$(printf '%s\n' "${filtered}" | grep -vF "${marker}" || true)"
  done
  if [[ "${filtered}" == "${existing}" ]]; then
    return 0
  fi
  if [[ -z "$(printf '%s' "${filtered}" | tr -d '[:space:]')" ]]; then
    crontab -r 2>/dev/null || true
  else
    write_crontab "${filtered}"
  fi
}

cmd_remove() {
  local project_ref="" assume_yes="" delete_workspace=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes|-y) assume_yes="1"; shift ;;
      --delete-workspace) delete_workspace="1"; shift ;;
      --help|-h)
        printf 'Usage: lumen remove <project-slug-or-name> [--yes] [--delete-workspace]\n'
        printf '\n'
        printf 'Removes the project registration, clears it as the default when applicable, and removes its scheduled scan.\n'
        printf 'The workspace is retained by default. Use --delete-workspace --yes to also delete the registered lumen folder.\n'
        return 0
        ;;
      --*) err "Unknown option: $1"; exit 1 ;;
      *)
        if [[ -z "${project_ref}" ]]; then
          project_ref="$1"
        else
          err "Unexpected argument: $1"
          exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "${project_ref}" ]]; then
    err "Usage: lumen remove <project-slug-or-name> [--yes] [--delete-workspace]"
    exit 1
  fi
  if [[ -n "${delete_workspace}" && -z "${assume_yes}" ]]; then
    err "--delete-workspace requires --yes because it permanently deletes the registered workspace."
    exit 1
  fi

  require_python3
  local project_json name slug workspace answer
  project_json="$(registry_cmd resolve "${project_ref}")" || { err "Project not found: ${project_ref}"; exit 1; }
  name="$(json_get "${project_json}" name)"
  slug="$(json_get "${project_json}" slug)"
  workspace="$(json_get "${project_json}" workspace)"

  if [[ -z "${assume_yes}" ]]; then
    printf 'Remove registered project %s (%s)?\n' "${name}" "${slug}"
    printf 'Workspace: %s\n' "${workspace}"
    if [[ -n "${delete_workspace}" ]]; then
      printf '%sThis will permanently delete that workspace directory.%s\n' "${YELLOW}" "${RESET}"
    else
      printf 'The workspace directory will be kept.\n'
    fi
    printf 'Continue? [y/N] '
    read -r answer || true
    if [[ ! "${answer}" =~ ^[Yy]([Ee][Ss])?$ ]]; then
      printf 'Cancelled.\n'
      return 0
    fi
  fi

  if [[ -n "${delete_workspace}" ]]; then
    if [[ "$(basename "${workspace}")" != "${LUMEN_DIR_NAME}" && "$(basename "${workspace}")" != "${LEGACY_LUMEN_DIR_NAME}" ]]; then
      err "Refusing to delete a workspace not named ${LUMEN_DIR_NAME}: ${workspace}"
      exit 1
    fi
    rm -rf "${workspace}"
  fi

  remove_schedule_for_slug "${slug}"
  registry_cmd remove "${slug}"
  ok "Removed registered project '${name}' (slug: ${slug})."
  if [[ -n "${delete_workspace}" ]]; then
    ok "Deleted workspace: ${workspace}"
  else
    printf 'Workspace kept at: %s\n' "${workspace}"
  fi
}

cmd_rename() {
  local project_ref="" new_slug=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --slug)
        new_slug="${2:-}"
        shift 2
        ;;
      --help|-h)
        printf 'Usage: lumen rename <project-slug-or-name> --slug <new-slug>\n'
        return 0
        ;;
      --*) err "Unknown option: $1"; exit 1 ;;
      *)
        if [[ -z "${project_ref}" ]]; then
          project_ref="$1"
        else
          err "Unexpected argument: $1"
          exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "${project_ref}" || -z "${new_slug}" ]]; then
    err "Usage: lumen rename <project-slug-or-name> --slug <new-slug>"
    exit 1
  fi

  require_python3
  local project_json name slug
  project_json="$(registry_cmd set-slug "${project_ref}" --slug "${new_slug}")" || exit 1
  name="$(json_get "${project_json}" name)"
  slug="$(json_get "${project_json}" slug)"
  ok "Updated '${name}' to slug: ${slug}"
}

cmd_use() {
  local arg="${1:-}"

  if [[ "${arg}" == "--unset" || "${arg}" == "--clear" ]]; then
    registry_cmd clear-default
    ok "Default project cleared."
    return 0
  fi

  if [[ -z "${arg}" ]]; then
    if registry_cmd get-default >/dev/null 2>&1; then
      local project_json name slug workspace
      project_json="$(registry_cmd get-default)"
      name="$(json_get "${project_json}" name)"
      slug="$(json_get "${project_json}" slug)"
      workspace="$(json_get "${project_json}" workspace)"
      printf 'Default project: %s (%s)\n' "${name}" "${slug}"
      printf 'Workspace: %s\n' "${workspace}"
    else
      printf 'No default project set.\n'
      printf 'Run: %slumen use <slug>%s   (see slugs with %slumen list%s)\n' "${BOLD}" "${RESET}" "${BOLD}" "${RESET}"
    fi
    return 0
  fi

  local project_json name slug
  project_json="$(registry_cmd set-default "${arg}")"
  name="$(json_get "${project_json}" name)"
  slug="$(json_get "${project_json}" slug)"
  ok "Default project set to '${name}' (slug: ${slug})"
  printf 'Run %slumen scan%s without --project to use this project.\n' "${BOLD}" "${RESET}"
}

cmd_register() {
  local target="."
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --*) ;;
      *) target="${arg}" ;;
    esac
  done

  target="$(cd "${target}" && pwd)"
  local workspace
  workspace="$(resolve_lumen_workspace_path "${target}")" || {
    err "No Lumen workspace found at: ${target} or ${target}/${LUMEN_DIR_NAME}"
    printf 'Run %slumen init%s in your project root first.\n' "${BOLD}" "${RESET}"
    exit 1
  }
  local reg_name project_json project_slug project_name
  reg_name="$(workspace_display_name "${workspace}")"
  project_json="$(register_project_workspace "${workspace}" "${reg_name}")"
  project_slug="$(json_get "${project_json}" slug)"
  project_name="$(json_get "${project_json}" name)"
  ok "Registered project '${project_name}' (slug: ${project_slug})"
  printf 'Workspace: %s\n' "${workspace}"
  printf 'Run: %slumen scan --project %s%s\n' "${BOLD}" "${project_slug}" "${RESET}"
}

cmd_scan() {
  if [[ "${1:-}" == "schedule" ]]; then
    shift
    cmd_schedule_scan "$@"
    return 0
  fi
  local dry_run=0
  local filtered_args=()
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --dry-run) dry_run=1 ;;
      *) filtered_args+=("${arg}") ;;
    esac
  done
  resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"
  if [[ "${dry_run}" == "1" ]]; then
    export LUMEN_DRY_RUN=1
  else
    unset LUMEN_DRY_RUN 2>/dev/null || true
  fi
  export LUMEN_CLI_BIN="${LUMEN_CLI_BIN}"
  bash "${LUMEN_LIB_DIR}/run-scan.sh" "${RESOLVED_WORKSPACE}"
}

cmd_dashboard() {
  if [[ "${1:-}" == "stop" ]]; then
    shift
    resolve_command_workspace "$@"
    local stop_state="${RESOLVED_WORKSPACE}/state/dashboard-server.json" stop_pid=""
    if [[ -f "${stop_state}" ]]; then
      stop_pid="$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('pid',''), end='')" "${stop_state}" 2>/dev/null || true)"
      if [[ "${stop_pid}" =~ ^[0-9]+$ ]] && kill -0 "${stop_pid}" 2>/dev/null; then
        kill "${stop_pid}"
        ok "Stopped interactive dashboard (PID ${stop_pid})."
      else
        warn "No running dashboard process was found."
      fi
      rm -f "${stop_state}"
    else
      warn "No interactive dashboard state found for this workspace."
    fi
    return 0
  fi
  local static_mode="0" filtered_args=() arg
  for arg in "$@"; do
    if [[ "${arg}" == "--static" ]]; then
      static_mode="1"
    else
      filtered_args+=("${arg}")
    fi
  done
  resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"
  local workspace="${RESOLVED_WORKSPACE}"
  bash "${LUMEN_LIB_DIR}/render-dashboard.sh" "${workspace}"

  local open_flag="1"
  local arg
  for arg in "${RESOLVED_REMAINING_ARGS[@]+"${RESOLVED_REMAINING_ARGS[@]}"}" "$@"; do
    if [[ "${arg}" == "--no-open" ]]; then
      open_flag="0"
    fi
  done

  if [[ "${static_mode}" == "1" ]]; then
    printf 'Dashboard (static): %s/dashboard.html\n' "${workspace}"
    return 0
  fi

  local dashboard_server="${LUMEN_LIB_DIR}/dashboard_server.py"
  [[ -f "${dashboard_server}" ]] || { err "Interactive dashboard server not found: ${dashboard_server}"; exit 1; }
  local project_json project_slug server_state server_url server_pid dashboard_version server_version
  project_json="$(registry_cmd resolve-workspace "${workspace}")" || { err "Workspace is not registered. Run: lumen register ${workspace}"; exit 1; }
  project_slug="$(json_get "${project_json}" slug)"
  server_state="${workspace}/state/dashboard-server.json"
  dashboard_version="$(lumen_version)"
  server_url=""
  if [[ -f "${server_state}" ]]; then
    server_pid="$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('pid',''), end='')" "${server_state}" 2>/dev/null || true)"
    if [[ "${server_pid}" =~ ^[0-9]+$ ]] && kill -0 "${server_pid}" 2>/dev/null; then
      server_version="$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('version',''), end='')" "${server_state}" 2>/dev/null || true)"
      if [[ "${server_version}" != "${dashboard_version}" ]]; then
        kill "${server_pid}" 2>/dev/null || true
        rm -f "${server_state}"
      else
      server_url="$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('url',''), end='')" "${server_state}" 2>/dev/null || true)"
      if [[ -z "${server_url}" ]] || ! curl -fsS --max-time 1 "${server_url%/}/api/state" >/dev/null 2>&1; then
        server_url=""
        rm -f "${server_state}"
      fi
      fi
    else
      rm -f "${server_state}"
    fi
  fi
  if [[ -z "${server_url}" ]]; then
    mkdir -p "${workspace}/logs"
    nohup python3 "${dashboard_server}" --workspace "${workspace}" --project "${project_slug}" --version "${dashboard_version}" \
      --lumen-bin "${LUMEN_CLI_BIN}" --lumen-home "${LUMEN_HOME}" \
      > "${workspace}/logs/dashboard-server.log" 2>&1 < /dev/null &
    local attempt
    for attempt in {1..30}; do
      if [[ -f "${server_state}" ]]; then
        server_url="$(python3 -c "import json; print(json.load(open('${server_state}')).get('url',''), end='')" 2>/dev/null || true)"
        if [[ -n "${server_url}" ]] && curl -fsS --max-time 1 "${server_url%/}/api/state" >/dev/null 2>&1; then
          break
        fi
        server_url=""
      fi
      sleep 0.1
    done
  fi
  [[ -n "${server_url}" ]] || { err "Interactive dashboard did not start. See ${workspace}/logs/dashboard-server.log"; exit 1; }

  printf 'Dashboard: %s\n' "${server_url}"
  if [[ "${open_flag}" == "1" ]]; then
    if command -v open >/dev/null 2>&1; then
      open "${server_url}"
    elif command -v xdg-open >/dev/null 2>&1; then
      xdg-open "${server_url}" >/dev/null 2>&1
    fi
  fi
}

cmd_watch() {
  resolve_command_workspace "$@"
  local workspace="${RESOLVED_WORKSPACE}"

  local logs_dir="${workspace}/logs"
  local latest_log
  latest_log="$(ls -t "${logs_dir}"/run-*.log 2>/dev/null | head -1 || true)"
  if [[ -z "${latest_log}" ]]; then
    err "No scan logs found in ${logs_dir}. Run 'lumen scan' first."
    exit 1
  fi

  printf 'Watching %s\n' "${latest_log}"
  printf 'Press Ctrl+C to stop.\n\n'

  if command -v python3 >/dev/null 2>&1 && [[ -f "${LUMEN_LIB_DIR}/format_scan_log.py" ]]; then
    tail -n 50 -f "${latest_log}" | python3 "${LUMEN_LIB_DIR}/format_scan_log.py"
  else
    tail -f "${latest_log}"
  fi
}

is_valid_cron_expr() {
  local expr="$1"
  local field_count
  field_count="$(printf '%s' "${expr}" | tr -s ' \t' ' ' | awk '{print NF}')"
  [[ "${field_count}" == "5" ]]
}

schedule_marker() {
  printf '# lumen-schedule:%s' "$1"
}

delivery_schedule_marker() {
  printf '# lumen-delivery-schedule:%s' "$1"
}

read_crontab() {
  crontab -l 2>/dev/null || true
}

write_crontab() {
  local content="$1"
  printf '%s\n' "${content}" | sed '/^[[:space:]]*$/d' | crontab -
}

prompt_schedule_cron() {
  local choice=""
  printf '\n%sChoose a scan schedule:%s\n' "${BOLD}" "${RESET}" >&2
  printf '  1) Daily at 09:00 (recommended)\n' >&2
  printf '  2) Weekdays at 09:00\n' >&2
  printf '  3) Every 6 hours\n' >&2
  printf '  4) Custom cron expression\n' >&2
  read -r -p "Choose [1-4, default 1]: " choice || true
  choice="${choice:-1}"
  case "${choice}" in
    1|"") printf '%s' "0 9 * * *" ;;
    2) printf '%s' "0 9 * * 1-5" ;;
    3) printf '%s' "0 */6 * * *" ;;
    4) prompt "Enter a 5-field cron expression" "0 9 * * *" ;;
    *) printf '%s' "0 9 * * *" ;;
  esac
}

cmd_schedule_add() {
  local slug="" cron_expr="" dry_run="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project) slug="${2:-}"; shift 2 ;;
      --cron) cron_expr="${2:-}"; shift 2 ;;
      --dry-run) dry_run="1"; shift ;;
      *) err "Unknown argument: $1"; exit 1 ;;
    esac
  done

  if [[ -z "${slug}" || -z "${cron_expr}" ]]; then
    if [[ ! -t 0 || ! -t 1 ]]; then
      err "Usage: lumen schedule add --project <slug> --cron \"<5-field cron expression>\" [--dry-run]"
      printf 'Example: lumen schedule add --project mbpass --cron "0 9 * * *"   (daily at 09:00)\n'
      exit 1
    fi
    printf '\n%sConfigure a recurring scan schedule%s\n' "${BOLD}" "${RESET}"
    if [[ -z "${slug}" ]]; then
      prompt_project_selection
      slug="${RESOLVED_PROJECT_SLUG}"
    fi
    if [[ -z "${cron_expr}" ]]; then
      cron_expr="$(prompt_schedule_cron)"
    fi
  fi

  if ! is_valid_cron_expr "${cron_expr}"; then
    err "Invalid cron expression: \"${cron_expr}\" (expected 5 space-separated fields: minute hour day-of-month month day-of-week)"
    exit 1
  fi

  local workspace
  workspace="$(registry_cmd resolve-slug "${slug}" --workspace-only)" || {
    err "Project not found: ${slug}. Run 'lumen list' to see available slugs."
    exit 1
  }
  require_workspace_initialized "${workspace}"

  local lumen_bin
  lumen_bin="$(command -v lumen || true)"
  if [[ -z "${lumen_bin}" ]]; then
    lumen_bin="${BASH_SOURCE[0]}"
  fi
  lumen_bin="$(cd "$(dirname "${lumen_bin}")" && pwd)/$(basename "${lumen_bin}")"

  local log_file="${workspace}/logs/schedule.log"
  mkdir -p "${workspace}/logs"

  local dry_run_flag=""
  [[ "${dry_run}" == "1" ]] && dry_run_flag=" --dry-run"

  local cron_path cron_env cron_line
  if [[ -f "${LUMEN_HOME}/lib/scripts/ensure-path.sh" ]]; then
    # shellcheck source=/dev/null
    source "${LUMEN_HOME}/lib/scripts/ensure-path.sh"
    cron_path="$(schedule_path_export "${lumen_bin}")"
    cron_env="$(schedule_env_export)"
  else
    cron_path="PATH=\"${HOME}/.local/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin\""
    cron_env="HOME=\"${HOME}\" SHELL=\"/bin/sh\" USER=\"${USER:-$(id -un)}\" LOGNAME=\"${LOGNAME:-${USER:-$(id -un)}}\""
  fi

  if [[ "$(uname -s)" == "Darwin" ]]; then
    local launchd_py schedule_json launchd_path description
    launchd_py="${LUMEN_HOME}/lib/scripts/scan_launchd.py"
    [[ -f "${launchd_py}" ]] || { err "launchd scheduler helper not found: ${launchd_py}"; exit 1; }
    schedule_json="$(python3 "${launchd_py}" add --project "${slug}" --cron "${cron_expr}" --lumen-bin "${lumen_bin}" --lumen-home "${LUMEN_HOME}" --path "${PATH}" --log-file "${log_file}" $([ "${dry_run}" == "1" ] && printf '%s' '--dry-run'))" || exit 1
    launchd_path="$(printf '%s' "${schedule_json}" | python3 -c 'import json,sys; print(json.load(sys.stdin)["path"], end="")')"
    description="$(printf '%s' "${schedule_json}" | python3 -c 'import json,sys; print(json.load(sys.stdin)["description"], end="")')"
    remove_legacy_scan_cron "${slug}"
    ok "Scheduled scan for '${slug}': ${description} with launchd$([ "${dry_run}" == "1" ] && echo ' (dry-run)')"
    printf 'LaunchAgent: %s\n' "${launchd_path}"
    printf 'Log file: %s\n' "${log_file}"
    return 0
  fi

  if ! command -v crontab >/dev/null 2>&1; then
    err "'crontab' is not available on this system. Scheduling requires cron."
    exit 1
  fi

  cron_line="${cron_expr} ${cron_path} ${cron_env} LUMEN_HOME=\"${LUMEN_HOME}\" \"${lumen_bin}\" scan --project ${slug}${dry_run_flag} >> \"${log_file}\" 2>&1 $(schedule_marker "${slug}")"

  local existing filtered updated
  existing="$(read_crontab)"
  filtered="$(printf '%s\n' "${existing}" | grep -vF "$(schedule_marker "${slug}")" || true)"
  updated="$(printf '%s\n%s' "${filtered}" "${cron_line}")"
  write_crontab "${updated}"

  ok "Scheduled scans for '${slug}': ${cron_expr}$([ "${dry_run}" == "1" ] && echo ' (dry-run)')"
  printf 'Log file: %s\n' "${log_file}"
  if [[ "${dry_run}" != "1" ]]; then
    load_env_file_if_present "${workspace}/.env.local"
    if [[ -z "${CURSOR_API_KEY:-}" ]]; then
      warn "Scheduled scans need CURSOR_API_KEY in ${workspace}/.env.local"
      printf '  Set it during lumen init or: lumen config set-cursor-api-key <key> --project %s\n' "${slug}"
    fi
    if [[ -z "${GH_TOKEN:-${GITHUB_TOKEN:-}}" ]]; then
      warn "Scheduled scans need GH_TOKEN in ${workspace}/.env.local for automated PR creation"
      printf '  Set it with: lumen config set-gh-token <token> --host <github-host> --project %s\n' "${slug}"
    fi
  fi
  printf 'Run %slumen schedule list%s to review all schedules.\n' "${BOLD}" "${RESET}"
}

cmd_schedule_remove() {
  local slug=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project) slug="${2:-}"; shift 2 ;;
      *) err "Unknown argument: $1"; exit 1 ;;
    esac
  done

  if [[ -z "${slug}" ]]; then
    err "Usage: lumen schedule remove --project <slug>"
    exit 1
  fi

  local removed_launchd="0"
  if [[ "$(uname -s)" == "Darwin" && -f "${LUMEN_HOME}/lib/scripts/scan_launchd.py" ]]; then
    python3 "${LUMEN_HOME}/lib/scripts/scan_launchd.py" remove --project "${slug}" || true
    removed_launchd="1"
  fi
  if ! command -v crontab >/dev/null 2>&1; then
    [[ "${removed_launchd}" == "1" ]] && { ok "Removed scan schedule for '${slug}'."; return 0; }
    err "'crontab' is not available on this system."
    exit 1
  fi

  local existing filtered
  existing="$(read_crontab)"
  if ! printf '%s\n' "${existing}" | grep -qF "$(schedule_marker "${slug}")"; then
    [[ "${removed_launchd}" == "1" ]] && { ok "Removed scan schedule for '${slug}'."; return 0; }
    warn "No scan schedule found for '${slug}'."
    return 0
  fi
  filtered="$(printf '%s\n' "${existing}" | grep -vF "$(schedule_marker "${slug}")" || true)"
  if [[ -z "$(printf '%s' "${filtered}" | tr -d '[:space:]')" ]]; then
    crontab -r 2>/dev/null || true
  else
    write_crontab "${filtered}"
  fi
  ok "Removed scan schedule for '${slug}'."
}

cron_label() {
  local expr="$1"
  case "${expr}" in
    "0 9 * * *") printf 'Daily at 09:00' ;;
    "0 9 * * 1-5") printf 'Weekdays at 09:00' ;;
    "0 */6 * * *") printf 'Every 6 hours' ;;
    *) printf '%s' "${expr}" ;;
  esac
}

cmd_schedule_list() {
  if [[ "$(uname -s)" == "Darwin" && -f "${LUMEN_HOME}/lib/scripts/scan_launchd.py" ]]; then
    local _ slug schedule_json path description
    while IFS=$'\t' read -r _ _ slug _ _; do
      [[ -n "${slug}" ]] || continue
      schedule_json="$(python3 "${LUMEN_HOME}/lib/scripts/scan_launchd.py" status --project "${slug}")"
      [[ -n "${schedule_json}" ]] || continue
      path="$(printf '%s' "${schedule_json}" | python3 -c 'import json,sys; print(json.load(sys.stdin)["path"], end="")')"
      description="$(printf '%s' "${schedule_json}" | python3 -c 'import json,sys; print(json.load(sys.stdin)["description"], end="")')"
      printf 'launchd  %-18s %-18s %s\n' "${slug}" "${description}" "${path}"
    done < <(registry_cmd list-lines)
  fi
  if ! command -v crontab >/dev/null 2>&1; then
    warn "'crontab' is not available on this system."
    return 0
  fi
  local lines
  lines="$(read_crontab | grep '# lumen-schedule:' || true)"
  if [[ -z "${lines}" ]]; then
    [[ "$(uname -s)" == "Darwin" ]] && return 0
    printf 'No Lumen scan schedules configured.\n'
    printf 'Add one with: lumen schedule scan add\n'
    return 0
  fi
  printf '%s%-26s %-18s %s%s\n' "${BOLD}" "CRON" "PROJECT" "DESCRIPTION" "${RESET}"
  while IFS= read -r line; do
    local slug cron_fields
    slug="$(printf '%s' "${line}" | sed -n 's/.*# lumen-schedule:\([^ ]*\).*/\1/p')"
    cron_fields="$(printf '%s' "${line}" | awk '{print $1, $2, $3, $4, $5}')"
    printf '%-26s %-18s %s\n' "${cron_fields}" "${slug}" "$(cron_label "${cron_fields}")"
  done <<< "${lines}"
}

remove_legacy_scan_cron() {
  local slug="$1"
  command -v crontab >/dev/null 2>&1 || return 0
  local existing filtered
  existing="$(read_crontab)"
  if ! printf '%s\n' "${existing}" | grep -qF "$(schedule_marker "${slug}")"; then
    return 0
  fi
  filtered="$(printf '%s\n' "${existing}" | grep -vF "$(schedule_marker "${slug}")" || true)"
  if [[ -z "$(printf '%s' "${filtered}" | tr -d '[:space:]')" ]]; then
    crontab -r 2>/dev/null || true
  else
    write_crontab "${filtered}"
  fi
}

remove_legacy_delivery_cron() {
  local slug="$1"
  command -v crontab >/dev/null 2>&1 || return 0
  local existing filtered
  existing="$(read_crontab)"
  if ! printf '%s\n' "${existing}" | grep -qF "$(delivery_schedule_marker "${slug}")"; then
    return 0
  fi
  filtered="$(printf '%s\n' "${existing}" | grep -vF "$(delivery_schedule_marker "${slug}")" || true)"
  if [[ -z "$(printf '%s' "${filtered}" | tr -d '[:space:]')" ]]; then
    crontab -r 2>/dev/null || true
  else
    write_crontab "${filtered}"
  fi
}

cmd_schedule_scan() {
  local sub="${1:-list}"
  shift || true
  case "${sub}" in
    add) cmd_schedule_add "$@" ;;
    remove|rm) cmd_schedule_remove "$@" ;;
    list|ls) cmd_schedule_list "$@" ;;
    *) err "Unknown scan schedule command: ${sub}"; exit 1 ;;
  esac
}

cmd_schedule() {
  local sub="${1:-list}"
  shift || true
  case "${sub}" in
    scan) cmd_schedule_scan "$@" ;;
    delivery) cmd_delivery_schedule "$@" ;;
    add|remove|rm)
      # Compatibility with Lumen <= 1.13.1: these commands target scan schedules.
      cmd_schedule_scan "${sub}" "$@"
      ;;
    list|ls)
      printf '%sScan schedules%s\n' "${BOLD}" "${RESET}"
      cmd_schedule_list
      printf '\n%sDelivery schedules%s\n' "${BOLD}" "${RESET}"
      cmd_delivery_schedule_list
      ;;
    *)
      printf 'Usage:\n'
      printf '  lumen schedule scan add --project <slug> --cron "0 9 * * *"\n'
      printf '  lumen schedule scan remove --project <slug>\n'
      printf '  lumen schedule delivery add --project <slug> --every 5m\n'
      printf '  lumen schedule delivery remove --project <slug>\n'
      printf '  lumen schedule list\n'
      exit 1
      ;;
  esac
}

delivery_docs_dir_for_project() {
  local slug="$1" workspace
  workspace="$(registry_cmd resolve-slug "${slug}" --workspace-only)" || return 1
  if [[ "$(basename "${workspace}")" == "${LUMEN_DIR_NAME}" || "$(basename "${workspace}")" == "${LEGACY_LUMEN_DIR_NAME}" ]]; then
    dirname "${workspace}"
  else
    printf '%s' "${workspace}"
  fi
}

cmd_delivery_schedule_run() {
  local slug="" jira_status="Ready for Dev" dry_run="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project) slug="${2:-}"; shift 2 ;;
      --jira-status) jira_status="${2:-}"; shift 2 ;;
      --dry-run) dry_run="1"; shift ;;
      *) err "Unknown argument: $1"; exit 1 ;;
    esac
  done
  [[ -n "${slug}" ]] || { err "Usage: lumen delivery schedule run --project <slug> [--jira-status <status>]"; exit 1; }
  local docs_dir workspace scheduler_py activity_file scheduler_log dry_flag=""
  docs_dir="$(delivery_docs_dir_for_project "${slug}")" || { err "Project not found: ${slug}"; exit 1; }
  workspace="${docs_dir}/${LUMEN_DIR_NAME}"
  [[ -d "${workspace}" ]] || workspace="${docs_dir}/${LEGACY_LUMEN_DIR_NAME}"
  scheduler_log="${workspace}/logs/delivery-schedule.log"
  activity_file="${workspace}/state/delivery-scheduler-activity.jsonl"
  mkdir -p "$(dirname "${scheduler_log}")" "$(dirname "${activity_file}")"
  # launchd keeps stdout open for this process, so truncate in place to retain its file handle.
  if [[ -f "${scheduler_log}" ]] && [[ $(wc -c < "${scheduler_log}") -ge 262144 ]]; then
    : > "${scheduler_log}"
    printf '[Lumen] Scheduler log truncated at 256 KiB; recent activity remains in Dashboard.\n'
  fi
  scheduler_py="${LUMEN_HOME}/lib/scripts/delivery_scheduler.py"
  [[ -f "${scheduler_py}" ]] || { err "Delivery scheduler not found: ${scheduler_py}"; exit 1; }
  [[ "${dry_run}" == "1" ]] && dry_flag="--dry-run"
  python3 "${scheduler_py}" --docs-dir "${docs_dir}" --jira-status "${jira_status}" --lumen-bin "${LUMEN_CLI_BIN}" --activity-file "${activity_file}" ${dry_flag}
}

cmd_delivery_schedule_add() {
  local slug="" cron_expr="" every="" jira_status="Ready for Dev"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project) slug="${2:-}"; shift 2 ;;
      --cron) cron_expr="${2:-}"; shift 2 ;;
      --every) every="${2:-}"; shift 2 ;;
      --jira-status) jira_status="${2:-}"; shift 2 ;;
      *) err "Unknown argument: $1"; exit 1 ;;
    esac
  done
  if [[ -n "${every}" ]]; then
    [[ -z "${cron_expr}" ]] || { err "Use either --every or --cron, not both."; exit 1; }
    [[ "${every}" =~ ^[1-9][0-9]*m$ ]] || { err "--every must be an interval such as 5m."; exit 1; }
    cron_expr="*/${every%m} * * * *"
  fi
  [[ -n "${slug}" && -n "${cron_expr}" ]] || { err "Usage: lumen schedule delivery add --project <slug> --every 5m [--jira-status <status>]"; exit 1; }
  is_valid_cron_expr "${cron_expr}" || { err "Invalid cron expression: ${cron_expr}"; exit 1; }
  [[ "${jira_status}" =~ ^[A-Za-z0-9[:space:]_-]+$ ]] || { err "JIRA status may only contain letters, numbers, spaces, underscores, and hyphens."; exit 1; }
  command -v crontab >/dev/null 2>&1 || { err "'crontab' is not available on this system."; exit 1; }

  local docs_dir workspace lumen_bin log_file cron_path cron_env cron_line existing filtered updated
  docs_dir="$(delivery_docs_dir_for_project "${slug}")" || { err "Project not found: ${slug}"; exit 1; }
  workspace="${docs_dir}/${LUMEN_DIR_NAME}"
  [[ -d "${workspace}" ]] || workspace="${docs_dir}/${LEGACY_LUMEN_DIR_NAME}"
  require_workspace_initialized "${workspace}"
  lumen_bin="$(command -v lumen || true)"
  lumen_bin="${lumen_bin:-${LUMEN_CLI_BIN}}"
  lumen_bin="$(cd "$(dirname "${lumen_bin}")" && pwd)/$(basename "${lumen_bin}")"
  log_file="${workspace}/logs/delivery-schedule.log"
  mkdir -p "$(dirname "${log_file}")"
  source "${LUMEN_HOME}/lib/scripts/ensure-path.sh"
  cron_path="$(schedule_path_export "${lumen_bin}")"
  cron_env="$(schedule_env_export)"
  if [[ "$(uname -s)" == "Darwin" && "${cron_expr}" =~ ^\*/[1-9][0-9]*\ \*\ \*\ \*\ \*$ ]]; then
    local launchd_py launchd_path
    launchd_py="${LUMEN_HOME}/lib/scripts/delivery_launchd.py"
    [[ -f "${launchd_py}" ]] || { err "launchd scheduler helper not found: ${launchd_py}"; exit 1; }
    launchd_path="$(python3 "${launchd_py}" add --project "${slug}" --cron "${cron_expr}" --jira-status "${jira_status}" --lumen-bin "${lumen_bin}" --lumen-home "${LUMEN_HOME}" --path "${PATH}" --log-file "${log_file}")" || exit 1
    local interval="${cron_expr%% *}"
    interval="${interval#*/}"
    remove_legacy_delivery_cron "${slug}"
    ok "Scheduled delivery polling for '${slug}' every ${interval} minute(s) with launchd (JIRA: ${jira_status})"
    printf 'LaunchAgent: %s\n' "${launchd_path}"
    printf 'Log file: %s\n' "${log_file}"
    return 0
  fi
  cron_line="${cron_expr} ${cron_path} ${cron_env} LUMEN_HOME=\"${LUMEN_HOME}\" \"${lumen_bin}\" delivery schedule run --project ${slug} --jira-status \"${jira_status}\" >> \"${log_file}\" 2>&1 $(delivery_schedule_marker "${slug}")"
  existing="$(read_crontab)"
  filtered="$(printf '%s\n' "${existing}" | grep -vF "$(delivery_schedule_marker "${slug}")" || true)"
  updated="$(printf '%s\n%s' "${filtered}" "${cron_line}")"
  write_crontab "${updated}"
  ok "Scheduled delivery polling for '${slug}': ${cron_expr} (JIRA: ${jira_status})"
  printf 'Log file: %s\n' "${log_file}"
}

cmd_delivery_schedule_remove() {
  local slug=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project) slug="${2:-}"; shift 2 ;;
      *) err "Unknown argument: $1"; exit 1 ;;
    esac
  done
  [[ -n "${slug}" ]] || { err "Usage: lumen delivery schedule remove --project <slug>"; exit 1; }
  local removed_launchd="0"
  if [[ "$(uname -s)" == "Darwin" && -f "${LUMEN_HOME}/lib/scripts/delivery_launchd.py" ]]; then
    python3 "${LUMEN_HOME}/lib/scripts/delivery_launchd.py" remove --project "${slug}" || true
    removed_launchd="1"
  fi
  command -v crontab >/dev/null 2>&1 || {
    [[ "${removed_launchd}" == "1" ]] && { ok "Removed delivery schedule for '${slug}'."; return 0; }
    err "'crontab' is not available on this system."; exit 1;
  }
  local existing filtered
  existing="$(read_crontab)"
  filtered="$(printf '%s\n' "${existing}" | grep -vF "$(delivery_schedule_marker "${slug}")" || true)"
  if [[ "${filtered}" == "${existing}" ]]; then
    warn "No delivery schedule found for '${slug}'."
    return 0
  fi
  write_crontab "${filtered}"
  ok "Removed delivery schedule for '${slug}'."
}

cmd_delivery_schedule_list() {
  if [[ "$(uname -s)" == "Darwin" && -f "${LUMEN_HOME}/lib/scripts/delivery_launchd.py" ]]; then
    local project_line slug schedule_json path interval_seconds interval_label
    while IFS=$'\t' read -r _ _ slug _ _; do
      [[ -n "${slug}" ]] || continue
      schedule_json="$(python3 "${LUMEN_HOME}/lib/scripts/delivery_launchd.py" status --project "${slug}")"
      [[ -n "${schedule_json}" ]] || continue
      path="$(printf '%s' "${schedule_json}" | python3 -c 'import json,sys; print(json.load(sys.stdin)["path"], end="")')"
      interval_seconds="$(printf '%s' "${schedule_json}" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("interval_seconds", 0), end="")')"
      if [[ "${interval_seconds}" =~ ^[1-9][0-9]*$ ]] && (( interval_seconds % 60 == 0 )); then
        interval_label="every $((interval_seconds / 60)) minutes"
      else
        interval_label="every ${interval_seconds} seconds"
      fi
      printf 'launchd  %-18s %-18s %s\n' "${slug}" "${interval_label}" "${path}"
    done < <(registry_cmd list-lines)
  fi
  command -v crontab >/dev/null 2>&1 || { warn "'crontab' is not available on this system."; return 0; }
  local lines
  lines="$(read_crontab | grep '# lumen-delivery-schedule:' || true)"
  if [[ -z "${lines}" ]]; then
    [[ "$(uname -s)" == "Darwin" ]] && return 0
    printf 'No Lumen delivery schedules configured.\n'
    return 0
  fi
  printf '%s\n' "${lines}"
}

cmd_delivery_schedule() {
  local sub="${1:-list}"
  shift || true
  case "${sub}" in
    add) cmd_delivery_schedule_add "$@" ;;
    remove|rm) cmd_delivery_schedule_remove "$@" ;;
    list|ls) cmd_delivery_schedule_list "$@" ;;
    run) cmd_delivery_schedule_run "$@" ;;
    *)
      printf 'Usage:\n'
      printf '  lumen schedule delivery add --project <slug> --every 5m [--jira-status "Ready for Dev"]\n'
      printf '  lumen schedule delivery remove --project <slug>\n'
      printf '  lumen schedule delivery list\n'
      ;;
  esac
}


delivery_workspace_root_from_docs() {
  local docs_dir="$1"
  local resolve_py="${LUMEN_HOME}/lib/scripts/resolve_delivery_workspace.py"
  if [[ -f "${resolve_py}" ]]; then
    python3 "${resolve_py}" "${docs_dir}"
    return
  fi
  python3 -c "from pathlib import Path
import json
docs = Path('${docs_dir}').resolve()
config = docs / 'lumen' / 'config' / 'workspace.json'
if not config.is_file():
    config = docs / '.lumen' / 'config' / 'workspace.json'
if config.is_file():
    data = json.loads(config.read_text())
    root = str(data.get('workspace_root', '')).strip()
    if root in {'.', './'}:
        print(str(docs), end='')
        raise SystemExit(0)
    if root:
        print(root, end='')
        raise SystemExit(0)
print(str(docs), end='')"
}

collect_delivery_repository() {
  local docs_dir="$1"
  local repos_root="$2"
  local setup_py="${LUMEN_HOME}/lib/scripts/setup_delivery_repositories.py"
  local name path clone_url

  [[ -f "${setup_py}" ]] || { err "Repository setup helper not found: ${setup_py}"; return 1; }

  name="$(prompt "Repository name" "")"
  [[ -n "${name}" ]] || return 1

  path="${repos_root}/${name}"
  while true; do
    clone_url="$(prompt "Git clone URL (leave blank if already present under repos/)" "")"
    if [[ -n "${clone_url}" ]]; then
      if [[ "${clone_url}" != *"/"* && "${clone_url}" != *":"* ]]; then
        warn "That doesn't look like a git URL: ${clone_url}"
        if ! prompt_yn "Try entering the URL again?" "y"; then
          return 1
        fi
        continue
      fi
      path="$(prompt "Clone into" "${path}")"
      if [[ -d "${path}/.git" ]]; then
        warn "Directory already looks like a git repo: ${path}"
        break
      fi
      if python3 "${setup_py}" add --docs-dir "${docs_dir}" --name "${name}" --path "${path}" --clone-url "${clone_url}"; then
        ok "Cloned and registered ${name}."
        return 0
      fi
      warn "Failed to clone ${name}"
      if ! prompt_yn "Try again?" "y"; then
        return 1
      fi
    else
      path="$(prompt "Local path to existing repository" "${path}")"
      if [[ -d "${path}/.git" ]]; then
        if python3 "${setup_py}" add --docs-dir "${docs_dir}" --name "${name}" --path "${path}"; then
          ok "Registered ${name}."
          return 0
        fi
        return 1
      fi
      warn "No git repository found at: ${path}"
      if ! prompt_yn "Try a different path?" "y"; then
        return 1
      fi
    fi
  done

  python3 "${setup_py}" add --docs-dir "${docs_dir}" --name "${name}" --path "${path}" || return 1
  ok "Registered ${name}."
  return 0
}

collect_delivery_repositories_interactively() {
  local docs_dir="$1"
  local repos_root="${docs_dir}/repos"

  mkdir -p "${repos_root}"
  touch "${repos_root}/.gitkeep"

  printf '\n%sCode repositories%s\n' "${BOLD}" "${RESET}"
  printf 'Repositories are stored under %s and ignored by the docs repo git history.\n\n' "${repos_root}"

  if ! prompt_yn "Add code repositories now?" "y"; then
    return 0
  fi

  while collect_delivery_repository "${docs_dir}" "${repos_root}"; do
    if ! prompt_yn "Add another repository?" "y"; then
      break
    fi
  done
}

cmd_legacy_workspace_init() {
  warn "This command is deprecated. Use: lumen init <workspace-dir>"
  cmd_init "$@"
}

cmd_delivery_configure() {
  local docs_dir=""
  local workspace_root=""
  local repos=()
  local replace_repositories="0"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --docs-dir)
        docs_dir="${2:-}"
        shift 2
        ;;
      --workspace-root)
        workspace_root="${2:-}"
        shift 2
        ;;
      --repo)
        repos+=("${2:-}")
        shift 2
        ;;
      --replace-repositories)
        replace_repositories="1"
        shift
        ;;
      --*)
        err "Unknown option: $1"
        exit 1
        ;;
      *)
        err "Unexpected argument: $1"
        exit 1
        ;;
    esac
  done

  [[ -n "${docs_dir}" ]] || { err "--docs-dir is required."; exit 1; }
  [[ -n "${workspace_root}" ]] || { err "--workspace-root is required."; exit 1; }
  local configure_py="${LUMEN_HOME}/lib/scripts/configure_delivery_workspace.py"
  [[ -f "${configure_py}" ]] || { err "Delivery workspace configurator not found: ${configure_py}"; exit 1; }
  local args=(--docs-dir "${docs_dir}" --workspace-root "${workspace_root}")
  local repo
  for repo in "${repos[@]}"; do
    args+=(--repo "${repo}")
  done
  [[ "${replace_repositories}" == "1" ]] && args+=(--replace-repositories)
  python3 "${configure_py}" "${args[@]}"
}

cmd_delivery_dashboard() {
  local docs_dir="."
  local no_open="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-open)
        no_open="1"
        shift
        ;;
      --*)
        err "Unknown option: $1"
        exit 1
        ;;
      *)
        docs_dir="$1"
        shift
        ;;
    esac
  done
  docs_dir="$(cd "${docs_dir}" && pwd)"
  local workspace_root
  workspace_root="$(delivery_workspace_root_from_docs "${docs_dir}")"
  local render_py="${LUMEN_HOME}/lib/scripts/render_delivery_dashboard.py"
  [[ -f "${render_py}" ]] || { err "Delivery dashboard renderer not found: ${render_py}"; exit 1; }
  local output
  output="$(python3 "${render_py}" --workspace-root "${workspace_root}")" || exit 1
  local html_path
  html_path="$(printf '%s' "${output}" | python3 -c 'import json,sys; print(json.load(sys.stdin)["html"], end="")')"
  ok "Delivery dashboard refreshed: ${html_path}"
  if [[ "${no_open}" != "1" ]] && command -v open >/dev/null 2>&1; then
    open "${html_path}"
  fi
}

