cmd_delivery_visual() {
  local docs_dir="." story_ref="" screen="" state=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --story) story_ref="${2:-}"; shift 2 ;;
      --screen) screen="${2:-}"; shift 2 ;;
      --state) state="${2:-}"; shift 2 ;;
      --*) err "Unknown option: $1"; exit 1 ;;
      *) docs_dir="$1"; shift ;;
    esac
  done
  [[ -n "${story_ref}" ]] || { err "Usage: lumen delivery visual --story <slug> [--screen <name>] [--state <name>] [workspace-dir]"; exit 1; }
  docs_dir="$(cd "${docs_dir}" && pwd)"
  local visual_py="${LUMEN_HOME}/lib/scripts/visual_delivery.py"
  [[ -f "${visual_py}" ]] || { err "Visual Delivery helper not found: ${visual_py}"; exit 1; }
  local args=(check --docs-dir "${docs_dir}" --story "${story_ref}")
  [[ -n "${screen}" ]] && args+=(--screen "${screen}")
  [[ -n "${state}" ]] && args+=(--state "${state}")
  python3 "${visual_py}" "${args[@]}"
}

cmd_delivery_pr() {
  delivery_docs_and_story_args "$@"
  local workspace_root workspace_dir
  workspace_root="$(delivery_workspace_root_from_docs "${DELIVERY_DOCS_DIR}")"
  local finalize_py="${LUMEN_HOME}/lib/scripts/finalize_delivery.py"
  workspace_dir="${workspace_root}/${LUMEN_DIR_NAME}"
  [[ -d "${workspace_dir}" ]] || workspace_dir="${workspace_root}/${LEGACY_LUMEN_DIR_NAME}"
  local result_file="${workspace_dir}/results/delivery-result.json"
  [[ -f "${finalize_py}" ]] || { err "Delivery finalization helper not found: ${finalize_py}"; exit 1; }
  [[ -f "${result_file}" ]] || { err "No delivery result found. Run delivery start first."; exit 1; }
  python3 "${finalize_py}" "${DELIVERY_DOCS_DIR}" --story "${DELIVERY_STORY_REF}" --result "${result_file}"
}

cmd_delivery_run() {
  local docs_dir="."
  local story_ref=""
  local dry_run="0"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --story)
        story_ref="${2:-}"
        shift 2
        ;;
      --dry-run)
        dry_run="1"
        shift
        ;;
      --*)
        err "Unknown option: $1"
        exit 1
        ;;
      *)
        docs_dir="$1"
        shift
        ;;
    esac
  done

  local run_script="${LUMEN_HOME}/lib/scripts/run-delivery.sh"
  if [[ ! -f "${run_script}" ]]; then
    err "Delivery runner not found: ${run_script}"
    exit 1
  fi
  command -v python3 >/dev/null 2>&1 || { err "Python 3 is required for delivery runs."; exit 1; }

  if [[ "${dry_run}" == "1" ]]; then
    LUMEN_DRY_RUN=1 bash "${run_script}" "${docs_dir}" --story "${story_ref}"
  else
    bash "${run_script}" "${docs_dir}" --story "${story_ref}"
  fi
}

cmd_delivery_status() {
  local docs_dir=""
  local workspace_root=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace_root="${2:-}"
        shift 2
        ;;
      --*)
        err "Unknown option: $1"
        exit 1
        ;;
      *)
        docs_dir="$1"
        shift
        ;;
    esac
  done

  if [[ -z "${workspace_root}" && -z "${docs_dir}" ]]; then
    local default_workspace
    default_workspace="$(registry_cmd get-default --workspace-only 2>/dev/null || true)"
    if [[ -n "${default_workspace}" ]]; then
      if [[ "$(basename "${default_workspace}")" == "${LUMEN_DIR_NAME}" || "$(basename "${default_workspace}")" == "${LEGACY_LUMEN_DIR_NAME}" ]]; then
        workspace_root="$(dirname "${default_workspace}")"
      else
        workspace_root="${default_workspace}"
      fi
    fi
  fi

  if [[ -z "${workspace_root}" && -n "${docs_dir}" ]]; then
    docs_dir="$(cd "${docs_dir}" && pwd)"
    workspace_root="$(delivery_workspace_root_from_docs "${docs_dir}")"
  fi

  if [[ -z "${workspace_root}" ]]; then
    if [[ -t 0 && -t 1 ]]; then
      read -r -p "Workspace root or docs repository path: " docs_dir || true
    fi
    if [[ -n "${docs_dir}" ]]; then
      docs_dir="$(cd "${docs_dir}" && pwd)"
      if [[ -d "${docs_dir}/stories" ]]; then
        workspace_root="$(delivery_workspace_root_from_docs "${docs_dir}")"
      else
        workspace_root="${docs_dir}"
      fi
    fi
  fi

  [[ -n "${workspace_root}" ]] || { err "Workspace root or docs repository path is required."; exit 1; }

  local progress_py="${LUMEN_HOME}/lib/scripts/delivery_progress.py"
  [[ -f "${progress_py}" ]] || { err "Delivery progress helper not found: ${progress_py}"; exit 1; }
  python3 "${progress_py}" report --workspace-root "${workspace_root}"
}

cmd_delivery_notify() {
  local docs_dir="." story_ref="" event="" send="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --story) story_ref="${2:-}"; shift 2 ;;
      --event) event="${2:-}"; shift 2 ;;
      --send) send="1"; shift ;;
      --*) err "Unknown argument: $1"; exit 1 ;;
      *) docs_dir="$1"; shift ;;
    esac
  done
  [[ -n "${story_ref}" && -n "${event}" ]] || {
    err "Usage: lumen delivery notify --story <slug-or-jira-key> --event <started|completed|failed|blocked> [--send] [workspace-dir]"
    exit 1
  }
  case "${event}" in started|completed|failed|blocked) ;; *) err "Unsupported delivery notification event: ${event}"; exit 1 ;; esac
  docs_dir="$(cd "${docs_dir}" && pwd)"
  local workspace_dir="${docs_dir}/${LUMEN_DIR_NAME}"
  [[ -d "${workspace_dir}" ]] || workspace_dir="${docs_dir}/${LEGACY_LUMEN_DIR_NAME}"
  load_env_file_if_present "${workspace_dir}/.env.common"
  load_env_file_if_present "${workspace_dir}/.env.local"
  local preview_py="${LUMEN_HOME}/lib/scripts/preview_delivery_notification.py"
  [[ -f "${preview_py}" ]] || { err "Delivery notification helper not found: ${preview_py}"; exit 1; }
  local args=("${docs_dir}" --story "${story_ref}" --event "${event}")
  [[ "${send}" == "1" ]] && args+=(--send)
  python3 "${preview_py}" "${args[@]}"
}

cmd_delivery_watch() {
  local docs_dir="."
  local workspace_root=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --workspace)
        workspace_root="${2:-}"
        shift 2
        ;;
      --*)
        err "Unknown option: $1"
        exit 1
        ;;
      *)
        docs_dir="$1"
        shift
        ;;
    esac
  done

  if [[ -z "${workspace_root}" && -n "${docs_dir}" ]]; then
    docs_dir="$(cd "${docs_dir}" && pwd)"
    workspace_root="$(delivery_workspace_root_from_docs "${docs_dir}")"
  fi

  [[ -n "${workspace_root}" ]] || { err "Docs repository path or workspace root is required."; exit 1; }

  local progress_py="${LUMEN_HOME}/lib/scripts/delivery_progress.py"
  local workspace_dir="${workspace_root}/${LUMEN_DIR_NAME}"
  [[ -d "${workspace_dir}" ]] || workspace_dir="${workspace_root}/${LEGACY_LUMEN_DIR_NAME}"
  local progress_file="${workspace_dir}/results/delivery-progress.json"
  local log_dir="${workspace_dir}/logs/delivery"
  local latest_log
  latest_log="$(ls -t "${log_dir}"/run-*.log 2>/dev/null | head -1 || true)"

  if [[ -f "${progress_py}" ]]; then
    python3 "${progress_py}" report --workspace-root "${workspace_root}" || true
  elif [[ -f "${progress_file}" ]]; then
    python3 -m json.tool "${progress_file}" || cat "${progress_file}"
  fi

  if [[ -z "${latest_log}" ]]; then
    err "No delivery logs found in ${log_dir}. Run 'lumen delivery run' first."
    exit 1
  fi

  printf '\nWatching %s\n' "${latest_log}"
  printf 'Press Ctrl+C to stop.\n\n'

  if command -v python3 >/dev/null 2>&1 && [[ -f "${LUMEN_HOME}/lib/scripts/format_scan_log.py" ]]; then
    tail -n 50 -f "${latest_log}" | python3 "${LUMEN_HOME}/lib/scripts/format_scan_log.py"
  else
    tail -f "${latest_log}"
  fi
}

cmd_delivery() {
  local sub="${1:-}"
  shift || true
  case "${sub}" in
    init-docs) cmd_legacy_workspace_init "$@" ;;
    configure) cmd_delivery_configure "$@" ;;
    dashboard) cmd_delivery_dashboard "$@" ;;
    schedule) cmd_delivery_schedule "$@" ;;
    sync) cmd_delivery_sync "$@" ;;
    prepare) cmd_delivery_prepare "$@" ;;
    verify) cmd_delivery_verify "$@" ;;
    visual) cmd_delivery_visual "$@" ;;
    pr) cmd_delivery_pr "$@" ;;
    start) cmd_delivery_run "$@" ;;
    run) cmd_delivery_run "$@" ;;
    status) cmd_delivery_status "$@" ;;
    notify) cmd_delivery_notify "$@" ;;
    watch) cmd_delivery_watch "$@" ;;
    ""|help|-h|--help)
      printf 'Usage:\n'
      printf '  lumen delivery dashboard [workspace-dir] [--no-open]\n'
      printf '  lumen delivery run [--story <slug-or-jira-key>] [--dry-run] [workspace-dir]\n'
      printf '  lumen delivery visual --story <slug> [--screen <name>] [--state <name>] [workspace-dir]\n'
      printf '  lumen delivery status [workspace-dir|--workspace <root>]\n'
      printf '  lumen delivery notify --story <slug-or-jira-key> --event <started|completed|failed|blocked> [--send] [workspace-dir]\n'
      printf '  lumen delivery watch [workspace-dir|--workspace <root>]\n'
      printf '  lumen delivery schedule add --project <slug> --cron "*/5 * * * *"\n'
      printf '\nExamples:\n'
      printf '  cd ~/Projects/mbpass-workspace\n'
      printf '  lumen delivery run --story MBPAS-1505\n'
      printf '  lumen delivery status\n'
      printf '  lumen delivery watch\n'
      ;;
    *)
      err "Unknown delivery command: ${sub}"
      printf 'Run: lumen delivery help\n'
      exit 1
      ;;
  esac
}

cmd_issue() {
  local sub="${1:-}"
  shift || true
  local issue_py="${LUMEN_HOME}/lib/scripts/issue_registry.py"

  case "${sub}" in
    list)
      local status="open" json_flag="" filtered_args=() arg
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project|-p|--workspace)
            filtered_args+=("$1" "${2:-}")
            shift 2
            ;;
          --status)
            status="${2:-open}"
            shift 2
            ;;
          --json)
            json_flag="1"
            shift
            ;;
          --*)
            err "Unknown option: $1"
            exit 1
            ;;
          *)
            err "Unexpected argument: $1"
            exit 1
            ;;
        esac
      done
      command -v python3 >/dev/null 2>&1 || { err "Python 3 is required."; exit 1; }
      [[ -f "${issue_py}" ]] || { err "Issue registry helper not found: ${issue_py}"; exit 1; }
      resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"
      local args=(list "${RESOLVED_WORKSPACE}" --status "${status}")
      [[ -n "${json_flag}" ]] && args+=(--json)
      python3 "${issue_py}" "${args[@]}"
      ;;
    ignore)
      local issue_id="" reason="" filtered_args=() arg
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project|-p|--workspace)
            filtered_args+=("$1" "${2:-}")
            shift 2
            ;;
          --reason)
            reason="${2:-}"
            shift 2
            ;;
          --*)
            err "Unknown option: $1"
            exit 1
            ;;
          *)
            if [[ -z "${issue_id}" ]]; then
              issue_id="$1"
            else
              err "Unexpected argument: $1"
              exit 1
            fi
            shift
            ;;
        esac
      done
      [[ -n "${issue_id}" ]] || { err "Usage: lumen issue ignore <issue-id> [--workspace <path>|--project <slug>] [--reason <text>]"; exit 1; }
      command -v python3 >/dev/null 2>&1 || { err "Python 3 is required."; exit 1; }
      [[ -f "${issue_py}" ]] || { err "Issue registry helper not found: ${issue_py}"; exit 1; }
      resolve_command_workspace "${filtered_args[@]+"${filtered_args[@]}"}"
      local args=(set-status "${RESOLVED_WORKSPACE}" "${issue_id}" ignored)
      [[ -n "${reason}" ]] && args+=(--reason "${reason}")
      python3 "${issue_py}" "${args[@]}"
      local dashboard_script="${LUMEN_HOME}/lib/scripts/render-dashboard.sh"
      if [[ -f "${dashboard_script}" ]]; then
        LUMEN_WORKSPACE="${RESOLVED_WORKSPACE}" bash "${dashboard_script}" "${RESOLVED_WORKSPACE}" >/dev/null 2>&1 || true
      fi
      ok "Ignored ${issue_id} in ${RESOLVED_WORKSPACE}/state/issue-registry.json"
      ;;
    ""|help|-h|--help)
      printf 'Usage:\n'
      printf '  lumen issue list [--workspace <path>|--project <slug>] [--status open|ignored|resolved|all] [--json]\n'
      printf '  lumen issue ignore <issue-id> [--workspace <path>|--project <slug>] [--reason <text>]\n'
      ;;
    *)
      err "Unknown issue command: ${sub}"
      printf 'Run: lumen issue help\n'
      exit 1
      ;;
  esac
}

main() {
  local command="${1:-help}"
  shift || true

  case "${command}" in
    init) cmd_init "$@" ;;
    list|ls) cmd_list "$@" ;;
    remove|rm|unregister) cmd_remove "$@" ;;
    rename) cmd_rename "$@" ;;
    use) cmd_use "$@" ;;
    register) cmd_register "$@" ;;
    scan) cmd_scan "$@" ;;
    schedule) cmd_schedule "$@" ;;
    set-up-docs|setup-docs) cmd_legacy_workspace_init "$@" ;;
    delivery) cmd_delivery "$@" ;;
    dashboard) cmd_dashboard "$@" ;;
    watch) cmd_watch "$@" ;;
    doctor) cmd_doctor "$@" ;;
    config) cmd_config "$@" ;;
    issue) cmd_issue "$@" ;;
    skills) cmd_skills "$@" ;;
    upgrade) cmd_upgrade "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help) cmd_help ;;
    *)
      err "Unknown command: ${command}"
      echo
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
