        ;;
      --*)
        err "Unknown option: $1"
        exit 1
        ;;
      *)
        DELIVERY_DOCS_DIR="$1"
        shift
        ;;
    esac
  done
  DELIVERY_DOCS_DIR="$(cd "${DELIVERY_DOCS_DIR}" && pwd)"
}

